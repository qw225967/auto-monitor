# SeeingStone API（真实请求示例见 README）
SEEINGSTONE_API_URL=https://seeingstone.cloud
SEEINGSTONE_API_TOKEN=your_bearer_token_here

# CoinGecko API Key（token 地址 + 流动性，Demo 免费 / Pro 付费 10 万/月）
# COINGECKO_API_KEY=your_coingecko_key
# COINGECKO_PRO=1   # Pro 用户设为 1
# TOKEN_REFRESH_TTL=604800 # token 信息刷新 TTL (秒)，默认 7d
# LIQUIDITY_SYNC_INTERVAL=14400  # 流动性全表同步间隔 (秒)，默认 4h
# LIQUIDITY_RETRY_MAX=3         # 每次流动性请求重试次数（不含首次）
# LIQUIDITY_BACKOFF_BASE_MS=500 # 重试退避基础毫秒
# LIQUIDITY_BACKOFF_MAX_MS=5000 # 重试退避最大毫秒
# LIQUIDITY_BACKOFF_JITTER=20   # 重试抖动百分比（±20%）
# LIQUIDITY_NEGATIVE_TTL=86400  # 负缓存 TTL（秒），404/无池默认 24h 不重复请求
# COINGECKO_BUDGET_ENABLED=1    # 启用预算管理（1=启用，0=关闭）
# COINGECKO_BUDGET_PATH=data/coingecko_budget.json # 预算状态文件路径
# COINGECKO_MONTHLY_LIMIT=100000 # CoinGecko 月请求上限
# PRIORITY_LIQUIDITY_SYNC_ENABLED=1  # 启用候选优先流动性同步
# PRIORITY_LIQUIDITY_SYNC_INTERVAL=300 # 候选优先同步间隔 (秒)
# PRIORITY_LIQUIDITY_TOP_ASSETS=30   # 每轮候选资产数
# PRIORITY_LIQUIDITY_MAX_REQUESTS=80 # 每轮最大请求数

# OKEx API Key（用于 DEX Quote / 链上价格，不配置则跳过 ChainPrice）
# OKEX_APP_KEY=your_app_key
# OKEX_SECRET_KEY=your_secret_key
# OKEX_PASSPHRASE=your_passphrase

# 交易所 API 密钥文件路径（用于充提网络查询，格式见 config/exchange_keys.json.example）
# EXCHANGE_KEYS_PATH=config/exchange_keys.json

# 价差过滤阈值 (%)
SPREAD_THRESHOLD=0.5

# 轮询间隔 (秒)
FETCH_INTERVAL=3
DETECT_INTERVAL=30
CHAIN_PRICE_INTERVAL=3
# RUN_DETECT_MAX_CONCURRENCY=64 # 通路探测并发上限
# RUN_DETECT_ROUTE_TIMEOUT=10   # 单路探测超时 (秒)

# HTTP 超时 (秒)，SeeingStone 数据量大(3万+)时建议 60
REQUEST_TIMEOUT=60

# 服务端口
SERVER_PORT=8088

# 开发模式：使用模拟数据，不请求真实 API
# MOCK_MODE=1
