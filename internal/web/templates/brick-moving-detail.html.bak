        // Pipeline相关函数（简化版，复用原有逻辑）
        function openPipelineConfig(direction) {
            currentPipelineDirection = direction;
            document.getElementById('pipelineTriggerSymbol').textContent = currentSymbol;
            document.getElementById('pipelineDirection').textContent = direction === 'forward' ? 'Forward (A → B)' : 'Backward (B → A)';
            document.getElementById('pipelineConfigModal').style.display = 'block';
            loadPipelineConfig(direction);
        }
        
        function closePipelineConfigModal() {
            document.getElementById('pipelineConfigModal').style.display = 'none';
        }
        
        async function loadPipelineConfig(direction) {
            try {
                const res = await fetch('/api/brick-moving/pipelines?triggerSymbol=' + encodeURIComponent(currentSymbol));
                const data = await res.json();
                const pipeline = direction === 'forward' ? data.forward : data.backward;
                currentPipelineNodes = pipeline && pipeline.nodes ? pipeline.nodes : [];
                renderPipelineNodes();
            } catch (error) {
                console.error('加载Pipeline配置失败:', error);
                currentPipelineNodes = [];
                renderPipelineNodes();
            }
        }
        
        function renderPipelineNodes() {
            const container = document.getElementById('pipelineNodesList');
            if (currentPipelineNodes.length === 0) {
                container.innerHTML = '<div style="text-align: center; color: #666; padding: 40px;">暂无节点，点击下方"添加节点"按钮开始配置</div>';
                return;
            }
            
            container.innerHTML = currentPipelineNodes.map((node, idx) => {
                const nodeName = node.name || node.exchangeType || node.chainName || '未知节点';
                return '<div style="display: flex; justify-content: space-between; align-items: center; padding: 10px; margin-bottom: 10px; background: #1a1a1a; border-radius: 4px; border: 1px solid #333;">' +
                    '<div>' +
                    '<strong style="color: #4ade80;">节点 ' + (idx + 1) + ':</strong> ' + nodeName +
                    '</div>' +
                    '<div style="display: flex; gap: 5px;">' +
                    '<button class="btn-secondary" onclick="editPipelineNode(' + idx + ')" style="padding: 4px 8px; font-size: 12px;">编辑</button> ' +
                    '<button class="btn-danger" onclick="removePipelineNode(' + idx + ')" style="padding: 4px 8px; font-size: 12px;">删除</button>' +
                    '</div>' +
                    '</div>';
            }).join('');
        }
        
        function addPipelineNode() {
            editingNodeIndex = -1;
            document.getElementById('nodeType').value = 'exchange';
            onNodeTypeChange();
            document.getElementById('pipelineNodeModal').style.display = 'block';
        }
        
        function editPipelineNode(index) {
            editingNodeIndex = index;
            const node = currentPipelineNodes[index];
            if (node.type === 'exchange') {
                document.getElementById('nodeType').value = 'exchange';
                document.getElementById('nodeExchangeType').value = node.exchangeType || 'binance';
                document.getElementById('nodeMarketType').value = node.marketType || 'spot';
            } else {
                document.getElementById('nodeType').value = 'chain';
                document.getElementById('nodeChainName').value = node.chainName || '';
            }
            onNodeTypeChange();
            document.getElementById('pipelineNodeModal').style.display = 'block';
        }
        
        function onNodeTypeChange() {
            const nodeType = document.getElementById('nodeType').value;
            document.getElementById('exchangeNodeConfig').style.display = nodeType === 'exchange' ? 'block' : 'none';
            document.getElementById('chainNodeConfig').style.display = nodeType === 'chain' ? 'block' : 'none';
        }
        
        function savePipelineNode() {
            const nodeType = document.getElementById('nodeType').value;
            let node = {};
            
            if (nodeType === 'exchange') {
                node = {
                    type: 'exchange',
                    exchangeType: document.getElementById('nodeExchangeType').value,
                    marketType: document.getElementById('nodeMarketType').value
                };
            } else {
                node = {
                    type: 'chain',
                    chainName: document.getElementById('nodeChainName').value
                };
            }
            
            if (editingNodeIndex >= 0) {
                currentPipelineNodes[editingNodeIndex] = node;
            } else {
                currentPipelineNodes.push(node);
            }
            
            renderPipelineNodes();
            closePipelineNodeModal();
        }
        
        function removePipelineNode(index) {
            if (confirm('确定要删除这个节点吗？')) {
                currentPipelineNodes.splice(index, 1);
                renderPipelineNodes();
            }
        }
        
        function closePipelineNodeModal() {
            document.getElementById('pipelineNodeModal').style.display = 'none';
            editingNodeIndex = -1;
        }
        
        async function savePipelineConfig() {
            // 转为 API 格式：type 为 binance/bitget 或 onchain:56，并带 asset
            const baseAsset = (currentTrigger && currentTrigger.symbol) ? currentTrigger.symbol.replace(/USDT$/i, '') : (currentSymbol || '').replace(/USDT$/i, '') || 'USDT';
            const nodesForApi = currentPipelineNodes.map((node, idx) => {
                const base = { asset: baseAsset, name: node.name || (node.exchangeType || node.chainName || 'node') + '-' + (idx + 1) };
                if (node.type === 'exchange') {
                    return Object.assign({}, base, { type: node.exchangeType || 'binance', network: node.network || 'ERC20' });
                }
                if (node.type === 'chain') {
                    const chainId = node.chainId || (node.chainName === 'BSC' ? '56' : (node.chainName === 'ETH' ? '1' : '56'));
                    return Object.assign({}, base, { type: 'onchain:' + chainId });
                }
                return Object.assign({}, base, node);
            });
            const edges = [];
            for (let i = 0; i < nodesForApi.length - 1; i++) {
                edges.push({ from: i, to: i + 1, amountType: 'all' });
            }
            try {
                const res = await fetch('/api/brick-moving/pipeline', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        triggerSymbol: currentSymbol,
                        direction: currentPipelineDirection,
                        nodes: nodesForApi,
                        edges: edges
                    })
                });
                
                if (res.ok) {
                    alert('Pipeline 配置已保存');
                    closePipelineConfigModal();
                    loadTriggerDetail(); // 重新加载
                } else {
                    alert('保存失败');
                }
            } catch (error) {
                alert('保存失败: ' + error.message);
            }
        }
        
        // 当前打开搜索充提链时的 Pipeline 方向（forward / backward），用于每行只显示一个「应用」按钮
        let currentChainSearchDirection = 'forward';
        // 路由探测结果（供外面列表展示）：{ direction, paths: [{path, segments, totalTimeSec, totalFee, altIndex, isRecommended}] }
        let lastRouteProbeCandidatesForList = null;
        // 搜索充提链：按方向填充源/目标/币种（A→B 用 base，B→A 用配置的 quoteAsset，默认 USDT）；执行探测时可传 triggerSymbol+direction 由后端统一解析
        function openChainSearch(direction) {
            currentChainSearchDirection = direction;
            const dirLabel = direction === 'forward' ? 'A→B' : 'B→A';
            const dirEl = document.getElementById('chainSearchDirection');
            if (dirEl) dirEl.textContent = dirLabel;
            const trigger = currentTrigger || {};
            const pipelines = trigger.pipelines || {};
            const baseAsset = (currentSymbol || '').replace(/USDT$/i, '').replace(/USDC$/i, '') || 'USDT';
            const quoteAsset = (trigger.hedging && trigger.hedging.quoteAsset) ? trigger.hedging.quoteAsset : 'USDT';
            let source = '', dest = '', symbol = '';
            if (direction === 'forward') {
                symbol = baseAsset;
                const nodes = pipelines.forward && pipelines.forward.nodes ? pipelines.forward.nodes : [];
                if (nodes.length >= 2) {
                    source = nodeToPathId(nodes[0]);
                    dest = nodeToPathId(nodes[nodes.length - 1]);
                } else {
                    source = (trigger.traderAType || '').trim() || 'binance';
                    dest = (trigger.traderBType || '').trim() || 'onchain:1';
                }
            } else {
                symbol = quoteAsset;
                const nodes = pipelines.backward && pipelines.backward.nodes ? pipelines.backward.nodes : [];
                if (nodes.length >= 2) {
                    source = nodeToPathId(nodes[0]);
                    dest = nodeToPathId(nodes[nodes.length - 1]);
                } else {
                    source = (trigger.traderBType || '').trim() || 'onchain:1';
                    dest = (trigger.traderAType || '').trim() || 'binance';
                }
            }
            const srcEl = document.getElementById('routeProbeSource');
            const dstEl = document.getElementById('routeProbeDest');
            const symEl = document.getElementById('routeProbeSymbol');
            const amtEl = document.getElementById('routeProbeAmount');
            if (srcEl) srcEl.value = source || '';
            if (dstEl) dstEl.value = dest || '';
            if (symEl) symEl.value = symbol || '';
            if (amtEl) amtEl.value = amtEl.value.trim() || '5';
            const results = document.getElementById('chainSearchResults');
            if (results) results.innerHTML = '<div style="text-align: center; color: #666; padding: 40px;">点击「执行路由探测」</div>';
            document.getElementById('chainSearchModal').style.display = 'block';
        }
        function nodeToPathId(node) {
            if (!node) return '';
            if (node.type && node.type.indexOf('onchain') === 0) return node.type;
            if (node.type && node.type !== 'exchange' && node.type !== 'chain') return node.type;
            if (node.exchangeType) return (node.marketType ? node.exchangeType + ':' + node.marketType : node.exchangeType);
            if (node.chainName) return 'onchain:' + (node.chainId || (node.chainName === 'BSC' ? '56' : node.chainName === 'ETH' ? '1' : '56'));
            return node.name || '';
        }
        
        function closeChainSearchModal() {
            document.getElementById('chainSearchModal').style.display = 'none';
        }
        
        // 渲染外面的列表：路由探测结果（在自动充提配置区），只有在此处应用才会在最上方区域显示
        function renderRouteProbeCandidatesBox() {
            const box = document.getElementById('routeProbeCandidatesBox');
            if (!box) return;
            if (!lastRouteProbeCandidatesForList || !lastRouteProbeCandidatesForList.paths || lastRouteProbeCandidatesForList.paths.length === 0) {
                box.innerHTML = '';
                return;
            }
            const dir = lastRouteProbeCandidatesForList.direction;
            const dirLabel = dir === 'forward' ? 'A→B' : 'B→A';
            const paths = lastRouteProbeCandidatesForList.paths;
            let html = '<div style="margin-top: 12px; padding: 10px; background: #1f1f1f; border-radius: 6px; border: 1px solid #333;">';
            html += '<div style="font-size: 13px; margin-bottom: 10px; color: #4ade80;"><strong>路由探测结果 (' + dirLabel + ')</strong> — 点击「应用」后将在最上方区域显示</div>';
            if (lastRouteProbeCandidatesForList.resolveSummary) {
                html += '<div style="font-size: 12px; margin-bottom: 8px; color: #888;">' + lastRouteProbeCandidatesForList.resolveSummary + '</div>';
            }
            paths.forEach(function(row) {
                const p = row.path || [];
                const segs = row.segments || [];
                let pathLabel = '';
                p.forEach(function(nodeId, idx) {
                    if (idx > 0) {
                        const seg = segs[idx - 1];
                        const lbl = (seg && seg.edgeLabel) ? seg.edgeLabel : '—';
                        pathLabel += ' → <span style="color: #60a5fa; font-size: 11px;">(' + lbl + ')</span> ';
                    }
                    pathLabel += nodeId;
                });
                const time = row.totalTimeSec != null ? row.totalTimeSec : 0;
                const fee = row.totalFee != null ? row.totalFee : '0';
                const altIdx = row.altIndex;
                const altArg = altIdx === null || altIdx === undefined ? 'null' : altIdx;
                html += '<div style="display: flex; justify-content: space-between; align-items: center; padding: 8px 10px; margin-bottom: 6px; background: #1a1a1a; border-radius: 4px; border: 1px solid #333;">';
                html += '<div><span style="color: #888;">' + pathLabel + '</span>';
                if (row.isRecommended) html += ' <span style="color: #4ade80; font-size: 11px;">(推荐)</span>';
                html += ' &nbsp; <span style="font-size: 12px;">' + time + '秒 / 损耗' + fee + '</span></div>';
                html += '<button class="btn-secondary" onclick="applyRouteProbeAsPipelineFromList(\'' + dir + '\', ' + altArg + ')" style="padding: 4px 10px; font-size: 12px;">应用</button>';
                html += '</div>';
            });
            html += '</div>';
            box.innerHTML = html;
        }
        
        let lastRouteProbeResult = null;
        
        async function runRouteProbe() {
            const srcEl = document.getElementById('routeProbeSource');
            const dstEl = document.getElementById('routeProbeDest');
            const symbolEl = document.getElementById('routeProbeSymbol');
            const amountEl = document.getElementById('routeProbeAmount');
            const source = (srcEl && srcEl.value.trim()) || 'binance';
            const dest = (dstEl && dstEl.value.trim()) || 'bitget';
            const symbol = (symbolEl && symbolEl.value.trim()) || (currentSymbol ? currentSymbol.replace(/USDT$/i, '') : '') || 'USDT';
            const amount = (amountEl && amountEl.value.trim()) || '5';
            const resultsDiv = document.getElementById('chainSearchResults');
            if (!resultsDiv) return;
            
            resultsDiv.innerHTML = '<div style="text-align: center; color: #888; padding: 40px;">探测中...</div>';
            
            const body = { source: source, destination: dest, symbol: symbol, probeAmount: amount };
            if (currentSymbol && (currentChainSearchDirection === 'forward' || currentChainSearchDirection === 'backward')) {
                body.triggerSymbol = currentSymbol;
                body.direction = currentChainSearchDirection;
            }
            
            try {
                const res = await fetch('/api/brick-moving/route-probe', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                const data = await res.json();
                lastRouteProbeResult = data;
                
                if (!res.ok) {
                    resultsDiv.innerHTML = '<div style="text-align: center; color: #f43f5e; padding: 20px;">探测失败: ' + (data.error || res.statusText || data) + '</div>';
                    return;
                }
                
                const path = data.path || [];
                const segments = data.segments || [];
                const alternatives = data.alternativePaths || [];
                const dirLabel = currentChainSearchDirection === 'forward' ? 'A→B' : 'B→A';
                
                // 合并为「路径列表」：第一项为主路径，其余为备选；每行一个「应用」按钮（当前 Pipeline 方向）
                const rows = [
                    { path: path, segments: segments, totalTimeSec: data.totalEstimatedTimeSec, totalFee: data.totalFee, isRecommended: true, altIndex: null }
                ];
                alternatives.forEach(function(alt, idx) {
                    const ap = alt.path || [];
                    const asegs = alt.segments || [];
                    const aTime = asegs.reduce(function(s, seg) { return s + (seg.estimatedTimeSec || 0); }, 0);
                    const aFee = alt.totalFee != null ? alt.totalFee : asegs.reduce(function(s, seg) { return s + parseFloat(seg.fee || '0'); }, 0).toFixed(6);
                    rows.push({ path: ap, segments: asegs, totalTimeSec: aTime, totalFee: aFee, isRecommended: false, altIndex: idx });
                });
                
                let html = '<div style="font-size: 13px;">路由路径列表（当前方向: ' + dirLabel + '，每行可应用为当前 Pipeline）</div>';
                rows.forEach(function(row) {
                    const p = row.path || [];
                    const segs = row.segments || [];
                    const time = row.totalTimeSec != null ? row.totalTimeSec : segs.reduce(function(s, seg) { return s + (seg.estimatedTimeSec || 0); }, 0);
                    const fee = row.totalFee != null ? row.totalFee : (segs.length ? segs.reduce(function(s, seg) { return s + parseFloat(seg.fee || '0'); }, 0).toFixed(6) : '0');
                    const altIndex = row.altIndex;
                    let pathTitleStr = '';
                    p.forEach(function(nodeId, idx) {
                        if (idx > 0 && segs[idx - 1]) {
                            const lbl = segs[idx - 1].edgeLabel || '—';
                            pathTitleStr += ' → <span style="color: #60a5fa; font-size: 11px;">(' + lbl + ')</span> ';
                        }
                        pathTitleStr += nodeId;
                    });
                    html += '<div style="border: 1px solid #333; border-radius: 6px; padding: 12px; margin-top: 10px; background: #1f1f1f; display: flex; flex-wrap: wrap; align-items: center; gap: 10px;">';
                    html += '<div style="flex: 1 1 100%;"><strong style="color: #4ade80;">路径:</strong> ' + pathTitleStr;
                    if (row.isRecommended) html += ' <span style="color: #4ade80; font-size: 12px;">(推荐)</span>';
                    html += '</div>';
                    html += '<div style="flex: 1 1 100%;">总耗时: ' + time + ' 秒 &nbsp; 总损耗: ' + fee + '</div>';
                    html += '<div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">';
                    p.forEach(function(nodeId, idx) {
                        if (idx > 0 && segs[idx - 1]) {
                            const seg = segs[idx - 1];
                            const ok = seg.available !== false;
                            html += '<span style="color: ' + (ok ? '#4ade80' : '#f43f5e') + ';">→</span>';
                            const lbl = seg.edgeLabel || '—';
                            html += '<span style="font-size: 11px; color: #888; margin-left: 2px;" title="边性质">(' + lbl + ')</span>';
                        }
                        html += '<span class="pipeline-node">' + nodeId + '</span>';
                    });
                    html += '</div>';
                    segs.forEach(function(seg, idx) {
                        if (seg && seg.type === 'bridge' && (seg.bridgeProtocol || seg.edgeLabel)) {
                            const lbl = seg.edgeLabel || seg.bridgeProtocol || '';
                            html += '<div style="flex: 1 1 100%; font-size: 12px; color: #888;">段' + (idx + 1) + ' 跨链: ' + (seg.fromNodeID || '') + ' → ' + (seg.toNodeID || '') + ' <strong style="color: #60a5fa;">' + lbl + '</strong>' + (seg.fee ? ' 费用 ' + seg.fee : '') + (seg.estimatedTimeSec ? ' 约' + seg.estimatedTimeSec + '秒' : '') + '</div>';
                        }
                    });
                    const unavailableReasons = [];
                    segs.forEach(function(seg, idx) {
                        if (seg && seg.available === false && seg.rawInfo && seg.rawInfo.reason) {
                            unavailableReasons.push('段' + (idx + 1) + ': ' + seg.rawInfo.reason);
                        }
                    });
                    if (unavailableReasons.length > 0) {
                        html += '<div style="flex: 1 1 100%; padding: 6px; background: #2a1a1a; border-left: 3px solid #f43f5e; font-size: 12px; color: #ccc;">' + unavailableReasons.join('；') + '</div>';
                    }
                    html += '<div style="flex: 1 1 100%; margin-top: 6px; display: flex; justify-content: flex-end;"><button class="btn-secondary" onclick="applyRouteProbeAsPipeline(' + (altIndex === null || altIndex === undefined ? 'null' : altIndex) + ')" style="padding: 6px 12px;">应用</button></div>';
                    html += '</div>';
                });
                if (data.verifyWithdrawHint) {
                    html += '<div style="margin-top: 12px; padding: 8px; background: #1a2a1a; border-left: 3px solid #60a5fa; font-size: 12px; color: #aaa;">' + data.verifyWithdrawHint + '</div>';
                }
                resultsDiv.innerHTML = html;
                
                // 把所有探测结果添加到外面的列表，供在自动充提配置区应用
                lastRouteProbeCandidatesForList = { direction: currentChainSearchDirection, paths: rows, resolveSummary: data.resolveSummary };
                renderRouteProbeCandidatesBox();
                closeChainSearchModal();
            } catch (error) {
                resultsDiv.innerHTML = '<div style="text-align: center; color: #f43f5e; padding: 20px;">探测失败: ' + error.message + '</div>';
            }
        }
        
        // 从外面列表点击「应用」时调用（direction 由探测时确定）
        async function applyRouteProbeAsPipelineFromList(direction, alternativeIndex) {
            if (!lastRouteProbeResult) {
                alert('请先执行路由探测');
                return;
            }
            await doApplyRouteProbeAsPipeline(direction, alternativeIndex);
        }
        
        async function applyRouteProbeAsPipeline(alternativeIndex) {
            if (!lastRouteProbeResult) {
                alert('请先执行路由探测');
                return;
            }
            await doApplyRouteProbeAsPipeline(currentChainSearchDirection, alternativeIndex);
        }
        
        async function doApplyRouteProbeAsPipeline(direction, alternativeIndex) {
            if (!lastRouteProbeResult) return;
            let path = lastRouteProbeResult.path;
            let segments = lastRouteProbeResult.segments || [];
            if (alternativeIndex != null && lastRouteProbeResult.alternativePaths && lastRouteProbeResult.alternativePaths[alternativeIndex]) {
                const alt = lastRouteProbeResult.alternativePaths[alternativeIndex];
                path = alt.path;
                segments = alt.segments || [];
            }
            if (!path || path.length < 2) return;
            const baseAsset = (currentTrigger && currentTrigger.symbol) ? currentTrigger.symbol.replace(/USDT$/i, '') : (currentSymbol || '').replace(/USDT$/i, '') || 'USDT';
            const nodesForApi = path.map((nodeId, idx) => {
                const name = nodeId + '-' + (idx + 1);
                if (nodeId.startsWith('onchain:')) {
                    return { type: nodeId, asset: baseAsset, name: name };
                }
                return { type: nodeId, asset: baseAsset, name: name, network: 'ERC20' };
            });
            // 与 executor.chainIDToNetwork 一致：链→交易所时充币网络由「来源链」决定
            function chainIDToNetwork(chainId) {
                var m = { '1': 'ERC20', '56': 'BEP20', '137': 'POLYGON', '42161': 'ARBITRUM', '10': 'OPTIMISM', '43114': 'AVAXC', '8453': 'BASE', '250': 'FTM', '25': 'CRO' };
                return m[String(chainId)] || '';
            }
            const edges = [];
            for (let i = 0; i < nodesForApi.length - 1; i++) {
                const edge = { from: i, to: i + 1, amountType: 'all' };
                var fromNodeId = path[i];
                var toNodeId = path[i + 1];
                if (segments[i] && segments[i].type === 'bridge' && segments[i].bridgeProtocol) {
                    edge.bridgeProtocol = segments[i].bridgeProtocol;
                }
                if (toNodeId && toNodeId.indexOf('onchain:') === 0) {
                    edge.chainId = toNodeId.replace('onchain:', '');
                }
                // 链→交易所：充币网络必须与来源链一致，否则 GetDepositAddress 会拿错网络
                if (fromNodeId && fromNodeId.indexOf('onchain:') === 0 && toNodeId && toNodeId.indexOf('onchain:') !== 0) {
                    var fromChainId = fromNodeId.replace('onchain:', '');
                    var net = chainIDToNetwork(fromChainId);
                    if (net) edge.network = net;
                }
                // 交易所→交易所：直接提到目标交易所充币地址，网络由提现链决定（不经过中间链地址）
                if (segments[i] && segments[i].type === 'exchange_to_exchange' && segments[i].withdrawNetworkChainID) {
                    var net = chainIDToNetwork(segments[i].withdrawNetworkChainID);
                    if (net) edge.network = net;
                    edge.chainId = segments[i].withdrawNetworkChainID; // 供后端 buildPipeline 缺 network 时用 chainId 推导
                }
                if (direction === 'backward') {
                    var quoteA = (currentTrigger && currentTrigger.hedging && currentTrigger.hedging.quoteAsset) ? currentTrigger.hedging.quoteAsset : 'USDT';
                    edge.asset = quoteA;
                }
                edges.push(edge);
            }
            try {
                const saveRes = await fetch('/api/brick-moving/pipeline', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        triggerSymbol: currentSymbol,
                        direction: direction,
                        nodes: nodesForApi,
                        edges: edges
                    })
                });
                if (!saveRes.ok) {
                    const saveText = await saveRes.text();
                    let saveErr = saveRes.statusText;
                    try { var d = JSON.parse(saveText); if (d.error) saveErr = d.error; } catch (e) { if (saveText) saveErr = saveText; }
                    alert('保存 Pipeline 配置失败：' + saveErr);
                    return;
                }
                const applyRes = await fetch('/api/brick-moving/pipeline/apply', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ triggerSymbol: currentSymbol, direction: direction })
                });
                const applyText = await applyRes.text();
                let applyData = {};
                try { applyData = JSON.parse(applyText); } catch (e) { if (applyText) applyData = { error: applyText }; }
                if (applyRes.ok && applyData.status === 'success') {
                    alert('已保存并应用为 ' + (direction === 'forward' ? 'A→B' : 'B→A') + ' Pipeline');
                    closeChainSearchModal();
                    loadTriggerDetail();  // 刷新后最上方区域将显示当前 Pipeline
                    loadWithdrawHistory(); // 刷新提币记录，显示 pipeline 可视化
                } else {
                    alert('应用失败：' + (applyData.error || applyRes.statusText));
                }
            } catch (e) {
                alert('操作失败：' + e.message);
            }
        }
        
        // 点击弹窗外部关闭
        window.onclick = function(event) {
            const modals = ['pipelineConfigModal', 'pipelineNodeModal', 'chainSearchModal'];
            modals.forEach(modalId => {
                const modal = document.getElementById(modalId);
                if (event.target === modal) {
                    if (modalId === 'pipelineConfigModal') closePipelineConfigModal();
                    else if (modalId === 'pipelineNodeModal') closePipelineNodeModal();
                    else if (modalId === 'chainSearchModal') closeChainSearchModal();
                }
            });
        }
        
        // ===================== 旧版入口已禁用 =====================
        // 说明：新 UI 由 React 在 #app 挂载后自行发起数据拉取与定时刷新。
        // 旧函数保留仅用于对照/回滚，但不再自动执行，避免出现双重请求与 DOM 互相覆盖。
    </script>

    <!-- React (无构建链：CDN UMD) -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/htm@3.1.1/dist/htm.umd.js"></script>
    <script>
        (function(){
            if (!window.React || !window.ReactDOM) {
                const el = document.getElementById('app');
                if (el) el.innerHTML = '<div class="aa-card"><div class="aa-cardTitle">加载失败</div><div class="aa-subtle" style="margin-top:8px;">React 资源未能加载（请检查网络）。</div></div>';
                return;
            }
            if (!window.htm) {
                const el = document.getElementById('app');
                if (el) el.innerHTML = '<div class="aa-card"><div class="aa-cardTitle">加载失败</div><div class="aa-subtle" style="margin-top:8px;">htm 资源未能加载（请检查网络）。</div></div>';
                return;
            }
            const {useEffect, useRef, useState} = React;
            const html = window.htm.bind(React.createElement);

            function getSymbolFromURL(){
                const path = window.location.pathname || '';
                const parts = path.split('/');
                if (parts.length >= 3 && parts[1] === 'brick-moving') {
                    try { return decodeURIComponent(parts[2]); } catch (e) { return parts[2]; }
                }
                return '';
            }

            async function fetchJSON(url, options){
                const res = await fetch(url, options);
                const text = await res.text();
                let data = null;
                try { data = text ? JSON.parse(text) : null; } catch (e) { data = null; }
                return { ok: res.ok, status: res.status, statusText: res.statusText, text, data };
            }

            function fmtNum(n, digits){
                const v = Number(n);
                if (!Number.isFinite(v)) return '--';
                if (typeof digits === 'number') return v.toFixed(digits);
                return String(v);
            }

            function pillForStatus(status){
                const s = (status || '').toLowerCase();
                if (s === 'running') return { cls: 'aa-pill aa-pillBlue', label: '运行中' };
                if (s === 'completed') return { cls: 'aa-pill aa-pillGreen', label: '已完成' };
                if (s === 'failed') return { cls: 'aa-pill aa-pillRed', label: '失败' };
                if (s === 'idle') return { cls: 'aa-pill aa-pillGray', label: '空闲' };
                if (s === 'stopped') return { cls: 'aa-pill aa-pillGray', label: '已停止' };
                if (s === 'not_found') return { cls: 'aa-pill aa-pillGray', label: '未找到' };
                return { cls: 'aa-pill aa-pillGray', label: status || '--' };
            }

            function nodeLabel(n){
                if (!n) return '';
                return n.name || n.id || '';
            }

            function pipelinePath(nodes){
                if (!Array.isArray(nodes) || nodes.length === 0) return '未配置';
                return nodes.map(nodeLabel).filter(Boolean).join(' → ');
            }

            function CollapsibleSection(props){
                const { title, summary, collapsedExtra, defaultCollapsed, children } = props;
                const [collapsed, setCollapsed] = useState(!!defaultCollapsed);
                const wrapRef = useRef(null);   // max-height transition element
                const innerRef = useRef(null);  // content height measure element
                const [maxHeight, setMaxHeight] = useState(collapsed ? 0 : null); // null => auto（展开后）
                const animatingRef = useRef(false);

                useEffect(() => {
                    const inner = innerRef.current;
                    if (!inner) return;
                    const full = inner.scrollHeight;

                    // 触发动画：展开/收起
                    animatingRef.current = true;
                    if (collapsed) {
                        // 收起：先固定当前高度，再下一帧变 0
                        setMaxHeight(full);
                        requestAnimationFrame(() => setMaxHeight(0));
                    } else {
                        // 展开：设置为内容高度，transitionend 后切换为 auto
                        setMaxHeight(full);
                    }
                }, [collapsed, children]);

                useEffect(() => {
                    const wrap = wrapRef.current;
                    if (!wrap) return;
                    const onEnd = (e) => {
                        if (e.propertyName !== 'max-height') return;
                        if (!animatingRef.current) return;
                        animatingRef.current = false;
                        if (!collapsed) setMaxHeight(null); // 展开结束 => auto
                    };
                    wrap.addEventListener('transitionend', onEnd);
                    return () => wrap.removeEventListener('transitionend', onEnd);
                }, [collapsed]);

                const btnText = collapsed ? '+ 展开' : '— 收起';

                return html`
                    <div className="aa-card">
                        <div className="aa-collapsibleHead">
                            <div className="aa-collapsibleTitle">${title}</div>
                            <button className="aa-toggleBtn" type="button" onClick=${() => setCollapsed(v => !v)}>${btnText}</button>
                        </div>
                        ${collapsed && summary ? html`<div className="aa-collapsibleSummary">${summary}</div>` : null}
                        ${collapsed && collapsedExtra ? html`<div style=${{marginTop: 10}}>${collapsedExtra}</div>` : null}
                        <div
                            className="aa-collapseWrap"
                            ref=${wrapRef}
                            style=${{ maxHeight: maxHeight === null ? 'none' : (maxHeight + 'px') }}
                        >
                            <div ref=${innerRef} className="aa-collapseInner">
                                ${children}
                            </div>
                        </div>
                    </div>
                `;
            }

            function App(){
                const [symbol] = useState(() => getSymbolFromURL());
                const [fillsState, setFillsState] = useState({ loading: true, error: '', fills: [] });
                const [withdrawState, setWithdrawState] = useState({ loading: true, error: '', forward: null, backward: null, records: [] });
                const [posState, setPosState] = useState({ loading: true, error: '', data: null, lastAt: 0 });
                const [hedgingCfg, setHedgingCfg] = useState({
                    loading: true, error: '',
                    enabled: true,
                    exchangeType: 'binance',
                    hedgingSymbol: '',
                    size: 1000,
                    syncWithTriggerSize: true,
                    position: 0,
                    autoWithdrawEnabled: false,
                    autoWithdrawUseFixed: true,
                    autoWithdrawFixedSize: 0,
                    autoWithdrawPercentage: 0,
                    quoteAsset: 'USDT',
                });
                const [hedgeUi, setHedgeUi] = useState({ saving: false, error: '', opening: false, openMsg: '' });

                // route probe states
                const [probeFwd, setProbeFwd] = useState({ source: '', dest: '', amount: '5', loading: false, error: '', rows: [] });
                const [probeBwd, setProbeBwd] = useState({ source: '', dest: '', amount: '5', loading: false, error: '', rows: [] });

                // auto-withdraw + swap states
                const autoTimersRef = useRef({ forward: null, backward: null });
                const [autoRunning, setAutoRunning] = useState({ forward: false, backward: false });
                const [autoUi, setAutoUi] = useState({ saving: false, error: '', last: { forward: null, backward: null } });
                const [swapUi, setSwapUi] = useState({ amount: '', direction: 'buy', source: 'A', loading: false, error: '', txHash: '' });
                const [priceDiff, setPriceDiff] = useState({ loading: true, error: '', exists: false, diffAB: null, diffBA: null });
                const [triggerState, setTriggerState] = useState({
                    loading: true, error: '',
                    status: '',
                    enabledAB: false,
                    enabledBA: false,
                    thresholdAB: 0.2,
                    thresholdBA: 0.0,
                    size: 1000,
                    onChainSlippage: '0.5',
                    gasLimit: '',
                    gasMultiplier: 1,
                });

                useEffect(() => {
                    const headerSymbolEl = document.getElementById('headerSymbol');
                    if (headerSymbolEl) headerSymbolEl.textContent = symbol || '--';
                    if (symbol) document.title = '搬砖详细信息 - ' + symbol;
                    // 兼容旧函数（仅用于打开 legacy modal）
                    try { window.currentSymbol = symbol || ''; } catch(e) {}
                }, [symbol]);

                // 价差：2 秒刷新
                useEffect(() => {
                    let cancelled = false;
                    let timer = null;
                    async function load(){
                        if (!symbol) return;
                        try{
                            const r = await fetchJSON('/api/brick-moving/trigger/price-diff?triggerSymbol=' + encodeURIComponent(symbol));
                            if (cancelled) return;
                            if (!r.ok) {
                                setPriceDiff({ loading:false, error: (r.data && r.data.error) || r.text || r.statusText, exists:false, diffAB:null, diffBA:null });
                                return;
                            }
                            setPriceDiff({
                                loading:false, error:'',
                                exists: !!(r.data && r.data.exists),
                                diffAB: (r.data && r.data.diffAB != null) ? Number(r.data.diffAB) : null,
                                diffBA: (r.data && r.data.diffBA != null) ? Number(r.data.diffBA) : null,
                            });
                        }catch(e){
                            if (cancelled) return;
                            setPriceDiff({ loading:false, error: e.message || String(e), exists:false, diffAB:null, diffBA:null });
                        }
                    }
                    load();
                    timer = setInterval(load, 2000);
                    return () => { cancelled = true; if (timer) clearInterval(timer); };
                }, [symbol]);

                // Trigger 状态/方向开关：用 /api/trigger?symbol 获取 enabledAB/enabledBA + status；阈值用 /api/brick-moving/triggers 列表补齐
                async function loadTriggerState(){
                    if (!symbol) return;
                    setTriggerState(s => ({...s, loading:true, error:''}));
                    try{
                        const [a, b] = await Promise.all([
                            fetchJSON('/api/trigger?symbol=' + encodeURIComponent(symbol)),
                            fetchJSON('/api/brick-moving/triggers')
                        ]);
                        const enabledAB = a.ok && a.data ? !!a.data.enabledAB : false;
                        const enabledBA = a.ok && a.data ? !!a.data.enabledBA : false;
                        const status = a.ok && a.data ? (a.data.status || '') : '';

                        let thresholdAB = 0.2;
                        let thresholdBA = 0.0;
                        let onChainSlippage = '0.5';
                        let gasMultiplier = 1;
                        let gasLimit = '';
                        if (b.ok && Array.isArray(b.data)) {
                            const row = b.data.find(x => x && x.symbol === symbol);
                            if (row) {
                                if (row.thresholdAB != null) thresholdAB = Number(row.thresholdAB);
                                if (row.thresholdBA != null) thresholdBA = Number(row.thresholdBA);
                                // 链上参数（优先 A 侧）
                                if (row.onChainSlippageA) onChainSlippage = String(row.onChainSlippageA);
                                else if (row.onChainSlippageB) onChainSlippage = String(row.onChainSlippageB);
                                if (row.gasMultiplierA != null) gasMultiplier = Number(row.gasMultiplierA) || 1;
                                else if (row.gasMultiplierB != null) gasMultiplier = Number(row.gasMultiplierB) || 1;
                                if (row.onChainGasLimitA) gasLimit = String(row.onChainGasLimitA);
                                else if (row.onChainGasLimitB) gasLimit = String(row.onChainGasLimitB);
                            }
                        }
                        // size 默认使用套保 size（因为后端不直接返回 size）
                        const size = Number(hedgingCfg.size) || 1000;

                        setTriggerState(s => ({
                            ...s,
                            loading:false,
                            error: (!a.ok && ((a.data && a.data.error) || a.text || a.statusText)) || (!b.ok && ((b.data && b.data.error) || b.text || b.statusText)) || '',
                            status,
                            enabledAB,
                            enabledBA,
                            thresholdAB,
                            thresholdBA,
                            size,
                            onChainSlippage,
                            gasLimit,
                            gasMultiplier,
                        }));
                    }catch(e){
                        setTriggerState(s => ({...s, loading:false, error: e.message || String(e)}));
                    }
                }

                useEffect(() => { loadTriggerState(); }, [symbol, hedgingCfg.size]); // eslint-disable-line react-hooks/exhaustive-deps

                async function updateTriggerConfig(patch){
                    if (!symbol) return;
                    const body = { symbol, ...(patch || {}) };
                    const r = await fetchJSON('/api/brick-moving/trigger/config', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
                    if (!r.ok) {
                        alert('更新失败：' + ((r.data && r.data.error) || r.text || r.statusText));
                        return false;
                    }
                    await loadTriggerState();
                    return true;
                }

                // 套保配置（主要用于 backward 的 QuoteAsset）
                useEffect(() => {
                    let cancelled = false;
                    async function load(){
                        if (!symbol) return;
                        setHedgingCfg(s => ({...s, loading: true, error: ''}));
                        try{
                            const r = await fetchJSON('/api/brick-moving/trigger/hedging?triggerSymbol=' + encodeURIComponent(symbol));
                            if (cancelled) return;
                            const d = (r.data && typeof r.data === 'object') ? r.data : {};
                            setHedgingCfg({
                                loading: false,
                                error: r.ok ? '' : (d.error) || r.text || r.statusText,
                                enabled: d.enabled !== undefined ? !!d.enabled : true,
                                exchangeType: d.exchangeType || 'binance',
                                hedgingSymbol: d.hedgingSymbol || symbol,
                                size: (d.size != null ? Number(d.size) : 1000) || 0,
                                syncWithTriggerSize: d.syncWithTriggerSize !== undefined ? !!d.syncWithTriggerSize : true,
                                position: (d.position != null ? Number(d.position) : 0) || 0,
                                autoWithdrawEnabled: !!d.autoWithdrawEnabled,
                                autoWithdrawUseFixed: d.autoWithdrawUseFixed !== undefined ? !!d.autoWithdrawUseFixed : true,
                                autoWithdrawFixedSize: (d.autoWithdrawFixedSize != null ? Number(d.autoWithdrawFixedSize) : 0) || 0,
                                autoWithdrawPercentage: (d.autoWithdrawPercentage != null ? Number(d.autoWithdrawPercentage) : 0) || 0,
                                quoteAsset: (d.quoteAsset || 'USDT') || 'USDT',
                            });
                        }catch(e){
                            if (cancelled) return;
                            setHedgingCfg(s => ({...s, loading: false, error: e.message || String(e)}));
                        }
                    }
                    load();
                    return () => { cancelled = true; };
                }, [symbol]);

                // 交易记录（当前后端会返回空列表，但 UI 仍对接）
                useEffect(() => {
                    let cancelled = false;
                    async function run(){
                        if (!symbol) return;
                        setFillsState(s => ({...s, loading: true, error: ''}));
                        try {
                            const r = await fetchJSON('/api/brick-moving/trigger/fills?triggerSymbol=' + encodeURIComponent(symbol) + '&limit=20');
                            if (cancelled) return;
                            const fills = r.data && Array.isArray(r.data.fills) ? r.data.fills : [];
                            setFillsState({ loading: false, error: r.ok ? '' : (r.data && r.data.error) || r.text || r.statusText, fills });
                        } catch (e) {
                            if (cancelled) return;
                            setFillsState({ loading: false, error: e.message || String(e), fills: [] });
                        }
                    }
                    run();
                    return () => { cancelled = true; };
                }, [symbol]);

                // 提币记录 + pipeline 路径（轮询，后续可按 running 状态加速）
                const reloadWithdraw = async () => {
                    if (!symbol) return;
                    setWithdrawState(s => ({...s, loading: true, error: ''}));
                    try {
                        const r = await fetchJSON('/api/brick-moving/withdraw-history?triggerSymbol=' + encodeURIComponent(symbol) + '&limit=10');
                        // 兼容：后端在某些情况下可能返回 []
                        if (Array.isArray(r.data)) {
                            setWithdrawState({ loading: false, error: '', forward: null, backward: null, records: [] });
                            return;
                        }
                        const pipelines = r.data && r.data.pipelines ? r.data.pipelines : {};
                        const forward = pipelines && pipelines.forward ? pipelines.forward : null;
                        const backward = pipelines && pipelines.backward ? pipelines.backward : null;
                        const records = r.data && Array.isArray(r.data.records) ? r.data.records : [];
                        setWithdrawState({ loading: false, error: r.ok ? '' : (r.data && r.data.error) || r.text || r.statusText, forward, backward, records });
                    } catch (e) {
                        setWithdrawState({ loading: false, error: e.message || String(e), forward: null, backward: null, records: [] });
                    }
                };
                useEffect(() => {
                    let timer = null;
                    reloadWithdraw();
                    timer = setInterval(reloadWithdraw, 5000);
                    return () => { if (timer) clearInterval(timer); };
                }, [symbol]); // eslint-disable-line react-hooks/exhaustive-deps

                // 持仓（按钮刷新 + 初次加载）
                const refreshPos = async () => {
                    if (!symbol) return;
                    setPosState(s => ({...s, loading: true, error: ''}));
                    try {
                        const r = await fetchJSON('/api/brick-moving/trigger/hedging-position?triggerSymbol=' + encodeURIComponent(symbol));
                        const data = r.data && typeof r.data === 'object' ? r.data : null;
                        setPosState({ loading: false, error: r.ok ? '' : (r.data && r.data.error) || r.text || r.statusText, data, lastAt: Date.now() });
                    } catch (e) {
                        setPosState({ loading: false, error: e.message || String(e), data: null, lastAt: Date.now() });
                    }
                };
                useEffect(() => { refreshPos(); }, [symbol]); // eslint-disable-line react-hooks/exhaustive-deps

                const forwardPath = pipelinePath(withdrawState.forward && withdrawState.forward.nodes);
                const backwardPath = pipelinePath(withdrawState.backward && withdrawState.backward.nodes);

                // 初始化 route probe 默认输入（基于当前 active pipeline）
                useEffect(() => {
                    if (!symbol) return;
                    const fwdNodes = withdrawState.forward && Array.isArray(withdrawState.forward.nodes) ? withdrawState.forward.nodes : [];
                    const bwdNodes = withdrawState.backward && Array.isArray(withdrawState.backward.nodes) ? withdrawState.backward.nodes : [];
                    const fallbackFwdSrc = (fwdNodes[0] && (fwdNodes[0].id || fwdNodes[0].name)) || 'binance';
                    const fallbackFwdDst = (fwdNodes[fwdNodes.length - 1] && (fwdNodes[fwdNodes.length - 1].id || fwdNodes[fwdNodes.length - 1].name)) || 'okex';
                    const fallbackBwdSrc = (bwdNodes[0] && (bwdNodes[0].id || bwdNodes[0].name)) || 'okex';
                    const fallbackBwdDst = (bwdNodes[bwdNodes.length - 1] && (bwdNodes[bwdNodes.length - 1].id || bwdNodes[bwdNodes.length - 1].name)) || 'binance';
                    setProbeFwd(s => ({...s, source: s.source || fallbackFwdSrc, dest: s.dest || fallbackFwdDst }));
                    setProbeBwd(s => ({...s, source: s.source || fallbackBwdSrc, dest: s.dest || fallbackBwdDst }));
                }, [symbol, withdrawState.forward, withdrawState.backward]);

                function baseAssetFromPair(pair){
                    const p = String(pair || '').trim();
                    if (!p) return '';
                    return p.replace(/USDT$/i,'').replace(/USDC$/i,'').replace(/BUSD$/i,'');
                }

                function buildRowsFromProbeResult(data){
                    if (!data) return [];
                    const main = { path: data.path || [], segments: data.segments || [], totalTimeSec: data.totalEstimatedTimeSec, totalFee: data.totalFee, isRecommended: true, altIndex: null };
                    const out = [main];
                    const alternatives = Array.isArray(data.alternativePaths) ? data.alternativePaths : [];
                    alternatives.forEach((alt, idx) => {
                        const ap = alt.path || [];
                        const asegs = alt.segments || [];
                        const aTime = Array.isArray(asegs) ? asegs.reduce((s, seg) => s + (seg.estimatedTimeSec || 0), 0) : 0;
                        const aFee = (alt.totalFee != null) ? alt.totalFee : (Array.isArray(asegs) ? asegs.reduce((s, seg) => s + parseFloat(seg.fee || '0'), 0).toFixed(6) : '0');
                        out.push({ path: ap, segments: asegs, totalTimeSec: aTime, totalFee: aFee, isRecommended: false, altIndex: idx });
                    });
                    return out;
                }

                async function runProbe(direction){
                    const isFwd = direction === 'forward';
                    const st = isFwd ? probeFwd : probeBwd;
                    const setSt = isFwd ? setProbeFwd : setProbeBwd;
                    const source = (st.source || '').trim();
                    const dest = (st.dest || '').trim();
                    const amount = (st.amount || '5').trim() || '5';
                    if (!source || !dest) {
                        setSt(s => ({...s, error: '请输入 source/dest' }));
                        return;
                    }
                    setSt(s => ({...s, loading: true, error: '' }));
                    try{
                        const probeSymbol = isFwd ? baseAssetFromPair(symbol) : (hedgingCfg.quoteAsset || 'USDT');
                        const body = { source, destination: dest, symbol: probeSymbol || 'USDT', probeAmount: amount, triggerSymbol: symbol, direction };
                        const r = await fetchJSON('/api/brick-moving/route-probe', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
                        if (!r.ok) {
                            setSt(s => ({...s, loading:false, error: (r.data && r.data.error) || r.text || r.statusText, rows: [] }));
                            return;
                        }
                        const rows = buildRowsFromProbeResult(r.data);
                        setSt(s => ({...s, loading:false, error:'', rows }));
                    }catch(e){
                        setSt(s => ({...s, loading:false, error: e.message || String(e), rows: [] }));
                    }
                }

                async function applyProbe(direction, row){
                    const isFwd = direction === 'forward';
                    const probeSymbol = isFwd ? baseAssetFromPair(symbol) : (hedgingCfg.quoteAsset || 'USDT');
                    const baseAsset = baseAssetFromPair(symbol) || 'USDT';
                    const quoteA = hedgingCfg.quoteAsset || 'USDT';
                    const path = row && Array.isArray(row.path) ? row.path : [];
                    const segments = row && Array.isArray(row.segments) ? row.segments : [];
                    if (path.length < 2) {
                        alert('路径无效');
                        return;
                    }

                    const nodesForApi = path.map((nodeId, idx) => {
                        const name = nodeId + '-' + (idx + 1);
                        if (String(nodeId).startsWith('onchain:')) {
                            return { type: nodeId, asset: baseAsset, name };
                        }
                        return { type: nodeId, asset: baseAsset, name, network: 'ERC20' };
                    });

                    function chainIDToNetwork(chainId) {
                        const m = { '1': 'ERC20', '56': 'BEP20', '137': 'POLYGON', '42161': 'ARBITRUM', '10': 'OPTIMISM', '43114': 'AVAXC', '8453': 'BASE', '250': 'FTM', '25': 'CRO' };
                        return m[String(chainId)] || '';
                    }

                    const edges = [];
                    for (let i = 0; i < nodesForApi.length - 1; i++) {
                        const edge = { from: i, to: i + 1, amountType: 'all' };
                        const fromNodeId = path[i];
                        const toNodeId = path[i + 1];
                        if (segments[i] && segments[i].type === 'bridge' && segments[i].bridgeProtocol) {
                            edge.bridgeProtocol = segments[i].bridgeProtocol;
                        }
                        if (toNodeId && String(toNodeId).indexOf('onchain:') === 0) {
                            edge.chainId = String(toNodeId).replace('onchain:', '');
                        }
                        // 链→交易所：充币网络必须与来源链一致
                        if (fromNodeId && String(fromNodeId).indexOf('onchain:') === 0 && toNodeId && String(toNodeId).indexOf('onchain:') !== 0) {
                            const fromChainId = String(fromNodeId).replace('onchain:', '');
                            const net = chainIDToNetwork(fromChainId);
                            if (net) edge.network = net;
                        }
                        // 交易所→交易所：网络由 withdrawNetworkChainID 决定
                        if (segments[i] && segments[i].type === 'exchange_to_exchange' && segments[i].withdrawNetworkChainID) {
                            const net = chainIDToNetwork(segments[i].withdrawNetworkChainID);
                            if (net) edge.network = net;
                            edge.chainId = segments[i].withdrawNetworkChainID;
                        }
                        if (!isFwd) {
                            edge.asset = quoteA;
                        }
                        edges.push(edge);
                    }

                    try{
                        const saveRes = await fetchJSON('/api/brick-moving/pipeline', {
                            method:'POST',
                            headers:{'Content-Type':'application/json'},
                            body: JSON.stringify({ triggerSymbol: symbol, direction, nodes: nodesForApi, edges })
                        });
                        if (!saveRes.ok) {
                            alert('保存 Pipeline 配置失败：' + ((saveRes.data && saveRes.data.error) || saveRes.text || saveRes.statusText));
                            return;
                        }
                        const applyRes = await fetchJSON('/api/brick-moving/pipeline/apply', {
                            method:'POST',
                            headers:{'Content-Type':'application/json'},
                            body: JSON.stringify({ triggerSymbol: symbol, direction })
                        });
                        if (!applyRes.ok || !(applyRes.data && applyRes.data.status === 'success')) {
                            alert('应用失败：' + ((applyRes.data && applyRes.data.error) || applyRes.text || applyRes.statusText));
                            return;
                        }
                        // localStorage 摘要（用于折叠态 ETA 展示）
                        try{
                            const key = 'aa.routeProbeSummary.' + symbol + '.' + direction;
                            const etaSec = row && row.totalTimeSec != null ? row.totalTimeSec : 0;
                            const pathText = Array.isArray(path) ? path.join('→') : '';
                            localStorage.setItem(key, JSON.stringify({ etaSec, pathText, at: Date.now(), probeSymbol }));
                        }catch(e){}

                        alert('已应用为 ' + (direction === 'forward' ? 'A→B' : 'B→A') + ' Pipeline');
                        reloadWithdraw(); // 刷新区块1的路径/状态
                    }catch(e){
                        alert('操作失败：' + (e.message || String(e)));
                    }
                }

                function probeSummaryText(){
                    const keyF = 'aa.routeProbeSummary.' + symbol + '.forward';
                    const keyB = 'aa.routeProbeSummary.' + symbol + '.backward';
                    let f = null, b = null;
                    try { f = JSON.parse(localStorage.getItem(keyF) || 'null'); } catch(e) {}
                    try { b = JSON.parse(localStorage.getItem(keyB) || 'null'); } catch(e) {}
                    const fOk = withdrawState.forward && Array.isArray(withdrawState.forward.nodes) && withdrawState.forward.nodes.length > 0;
                    const bOk = withdrawState.backward && Array.isArray(withdrawState.backward.nodes) && withdrawState.backward.nodes.length > 0;
                    const fTxt = fOk ? ('✅ A→B: ' + forwardPath + (f && f.etaSec ? (' ' + f.etaSec + 's') : '')) : '⚠️ A→B: 未配置';
                    const bTxt = bOk ? ('✅ B→A: ' + backwardPath + (b && b.etaSec ? (' ' + b.etaSec + 's') : '')) : '⚠️ B→A: 未配置';
                    return fTxt + ' │ ' + bTxt;
                }

                async function saveHedgingAll(next){
                    // next: partial override of hedgingCfg (in-memory) before saving
                    const merged = {...hedgingCfg, ...(next || {})};
                    setAutoUi(s => ({...s, saving: true, error: ''}));
                    try{
                        const body = {
                            symbol: symbol,
                            enabled: true,
                            exchangeType: merged.exchangeType,
                            hedgingSymbol: merged.hedgingSymbol || symbol,
                            size: Number(merged.size) || 0,
                            syncWithTriggerSize: !!merged.syncWithTriggerSize,
                            position: Number(merged.position) || 0,
                            autoWithdrawEnabled: !!merged.autoWithdrawEnabled,
                            autoWithdrawUseFixed: !!merged.autoWithdrawUseFixed,
                            autoWithdrawFixedSize: Number(merged.autoWithdrawFixedSize) || 0,
                            autoWithdrawPercentage: Number(merged.autoWithdrawPercentage) || 0,
                            quoteAsset: merged.quoteAsset || 'USDT',
                        };
                        const r = await fetchJSON('/api/brick-moving/trigger/hedging', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
                        if (!r.ok) {
                            setAutoUi(s => ({...s, saving: false, error: (r.data && r.data.error) || r.text || r.statusText}));
                            return false;
                        }
                        setHedgingCfg(s => ({...s, ...merged}));
                        setAutoUi(s => ({...s, saving: false, error: ''}));
                        return true;
                    }catch(e){
                        setAutoUi(s => ({...s, saving: false, error: e.message || String(e)}));
                        return false;
                    }
                }

                function getFixedSize(){
                    const fixed = Number(hedgingCfg.autoWithdrawFixedSize) || 0;
                    const fallback = Number(hedgingCfg.size) || 0;
                    return fixed > 0 ? fixed : fallback;
                }

                async function tickAuto(direction){
                    try{
                        const r = await fetchJSON('/api/brick-moving/pipeline/balance?triggerSymbol=' + encodeURIComponent(symbol) + '&direction=' + encodeURIComponent(direction));
                        if (!r.ok) {
                            setAutoUi(s => ({...s, last: {...s.last, [direction]: { ok:false, at: Date.now(), error: (r.data && r.data.error) || r.text || r.statusText }}}));
                            return;
                        }
                        const d = r.data || {};
                        const balance = Number(d.balance) || 0;
                        const balanceAsset = d.balanceAsset || '';
                        let threshold = 0;
                        if (direction === 'backward') {
                            // 后端可能提供 usdtThreshold（实际为 quoteAsset 阈值）
                            threshold = Number(d.usdtThreshold) || 0;
                            if (!threshold && hedgingCfg.autoWithdrawUseFixed) threshold = getFixedSize(); // fallback
                            if (!threshold && !hedgingCfg.autoWithdrawUseFixed) {
                                const pos = Number(hedgingCfg.position) || 0;
                                const pct = Number(hedgingCfg.autoWithdrawPercentage) || 0;
                                threshold = pos > 0 ? (pos * pct) : 0;
                            }
                        } else {
                            if (hedgingCfg.autoWithdrawUseFixed) threshold = getFixedSize();
                            else {
                                const pos = Number(hedgingCfg.position) || 0;
                                const pct = Number(hedgingCfg.autoWithdrawPercentage) || 0;
                                threshold = pos > 0 ? (pos * pct) : 0;
                            }
                        }

                        const shouldRun = threshold > 0 ? (balance >= threshold * 0.95) : (balance > 0);
                        setAutoUi(s => ({...s, last: {...s.last, [direction]: { ok:true, at: Date.now(), balance, balanceAsset, threshold, shouldRun }}}));
                        if (!shouldRun) return;

                        const rr = await fetchJSON('/api/brick-moving/pipeline/run?triggerSymbol=' + encodeURIComponent(symbol) + '&direction=' + encodeURIComponent(direction), { method:'POST' });
                        if (!rr.ok) {
                            setAutoUi(s => ({...s, last: {...s.last, [direction]: { ok:false, at: Date.now(), balance, balanceAsset, threshold, shouldRun, error: (rr.data && rr.data.error) || rr.text || rr.statusText }}}));
                            return;
                        }
                        reloadWithdraw();
                    }catch(e){
                        setAutoUi(s => ({...s, last: {...s.last, [direction]: { ok:false, at: Date.now(), error: e.message || String(e) }}}));
                    }
                }

                function startAuto(direction){
                    if (!symbol) return;
                    if (autoTimersRef.current[direction]) return;
                    // 立即 tick 一次，再开始轮询
                    tickAuto(direction);
                    autoTimersRef.current[direction] = setInterval(() => tickAuto(direction), 5000);
                    setAutoRunning(s => ({...s, [direction]: true}));
                }

                function stopAuto(direction){
                    const t = autoTimersRef.current[direction];
                    if (t) clearInterval(t);
                    autoTimersRef.current[direction] = null;
                    setAutoRunning(s => ({...s, [direction]: false}));
                }

                useEffect(() => {
                    return () => {
                        stopAuto('forward');
                        stopAuto('backward');
                    };
                }, []);

                return html`
                    <div className="aa-stack">
                        <div className="aa-grid3">
                            <div className="aa-card">
                                <div className="aa-cardTitle"><span>📋 交易记录</span><span className="aa-subtle">${symbol || '--'}</span></div>
                                ${fillsState.error ? html`<div className="aa-subtle" style=${{marginTop:10, color:'var(--aa-red)'}}>加载失败：${fillsState.error}</div>` : null}
                                ${fillsState.loading ? html`<div className="aa-subtle" style=${{marginTop:10}}>加载中...</div>` : null}
                                ${(!fillsState.loading && fillsState.fills.length === 0) ? html`<div className="aa-subtle" style=${{marginTop:10}}>暂无成交记录（该接口目前返回空列表，后续可接入交易所成交查询）。</div>` : null}
                                ${fillsState.fills.length > 0 ? html`
                                    <div className="aa-list">
                                        ${fillsState.fills.map((f, idx) => html`
                                            <div key=${idx} className="aa-listItem">
                                                <div className="aa-listMain">
                                                    <div className="aa-listTitle">${f.symbol || symbol || '--'} ${f.side || ''}</div>
                                                    <div className="aa-listSub aa-mono">qty=${f.qty || f.quantity || '--'} price=${f.price || '--'} time=${f.time || f.createTime || '--'}</div>
                                                </div>
                                            </div>
                                        `)}
                                    </div>
                                ` : null}
                            </div>
                            <div className="aa-card">
                                <div className="aa-cardTitle"><span>🚚 提币记录</span><span className="aa-subtle">A→B / B→A</span></div>
                                ${withdrawState.error ? html`<div className="aa-subtle" style=${{marginTop:10, color:'var(--aa-red)'}}>加载失败：${withdrawState.error}</div>` : null}
                                <div className="aa-list">
                                    <div className="aa-listItem">
                                        <div className="aa-listMain">
                                            <div className="aa-listTitle">A→B</div>
                                            <div className="aa-listSub aa-mono">${forwardPath}</div>
                                        </div>
                                        <div className=${pillForStatus(withdrawState.forward && withdrawState.forward.status).cls}>${pillForStatus(withdrawState.forward && withdrawState.forward.status).label}</div>
                                    </div>
                                    <div className="aa-listItem">
                                        <div className="aa-listMain">
                                            <div className="aa-listTitle">B→A</div>
                                            <div className="aa-listSub aa-mono">${backwardPath}</div>
                                        </div>
                                        <div className=${pillForStatus(withdrawState.backward && withdrawState.backward.status).cls}>${pillForStatus(withdrawState.backward && withdrawState.backward.status).label}</div>
                                    </div>
                                </div>
                                <div className="aa-divider"></div>
                                <div className="aa-cardTitle" style=${{fontSize:12, fontWeight:800}}><span>提币历史</span><span className="aa-subtle">最近 ${withdrawState.records.length} 条</span></div>
                                ${withdrawState.loading ? html`<div className="aa-subtle" style=${{marginTop:10}}>加载中...</div>` : null}
                                ${(!withdrawState.loading && withdrawState.records.length === 0) ? html`<div className="aa-subtle" style=${{marginTop:10}}>暂无提币记录。</div>` : null}
                                ${withdrawState.records.length > 0 ? html`
                                    <div className="aa-list">
                                        ${withdrawState.records.map((r, idx) => html`
                                            <div key=${idx} className="aa-listItem">
                                                <div className="aa-listMain">
                                                    <div className="aa-listTitle">${r.asset || '--'} ${r.amount || '--'} <span className="aa-subtle">(${r.network || '--'})</span></div>
                                                    <div className="aa-listSub aa-mono">${r.status || '--'} · ${r.createTime || '--'} · ${r.txHash ? ('tx=' + r.txHash) : ''}</div>
                                                </div>
                                                <div className="aa-pill aa-pillGray">${r.withdrawId || '--'}</div>
                                            </div>
                                        `)}
                                    </div>
                                ` : null}
                            </div>
                            <div className="aa-card">
                                <div className="aa-cardTitle"><span>📊 当前持仓</span><span className="aa-subtle">含中间链与 Gas</span></div>
                                ${posState.error ? html`<div className="aa-subtle" style=${{marginTop:10, color:'var(--aa-red)'}}>加载失败：${posState.error}</div>` : null}
                                <div className="aa-row" style=${{marginTop: 10}}>
                                    <button className="aa-btn aa-btnBlue" onClick=${refreshPos} disabled=${posState.loading}>实时刷新</button>
                                    <span className="aa-subtle">${posState.loading ? '刷新中...' : (posState.lastAt ? ('更新于 ' + new Date(posState.lastAt).toLocaleTimeString()) : '')}</span>
                                </div>
                                ${posState.data ? html`
                                    <div className="aa-kv aa-mono">
                                        <div className="aa-k">套保持仓</div><div className="aa-v">${fmtNum(posState.data.hedgingPosition, 4)} / USDT ${fmtNum(posState.data.hedgingPositionUsdt, 2)}</div>
                                        <div className="aa-k">A钱包</div><div className="aa-v">币 ${fmtNum(posState.data.aPositionCoin, 6)} / USDT ${fmtNum(posState.data.aPositionUsdt, 2)}</div>
                                        <div className="aa-k">B钱包</div><div className="aa-v">币 ${fmtNum(posState.data.bPositionCoin, 6)} / USDT ${fmtNum(posState.data.bPositionUsdt, 2)}</div>
                                    </div>
                                    ${Array.isArray(posState.data.intermediatePositions) && posState.data.intermediatePositions.length > 0 ? html`
                                        <div className="aa-divider"></div>
                                        <div className="aa-cardTitle" style=${{fontSize:12, fontWeight:800}}><span>中间链</span><span className="aa-subtle">${posState.data.intermediatePositions.length} 条</span></div>
                                        <div className="aa-list">
                                            ${posState.data.intermediatePositions.map((m, idx) => html`
                                                <div key=${idx} className="aa-listItem">
                                                    <div className="aa-listMain">
                                                        <div className="aa-listTitle">${m.chainName || m.chainId || '--'}</div>
                                                        <div className="aa-listSub aa-mono">币 ${fmtNum(m.coin, 6)} · ${m.gasToken || 'Gas'} ${fmtNum(m.gasBalance, 6)}</div>
                                                    </div>
                                                </div>
                                            `)}
                                        </div>
                                    ` : null}
                                ` : html`<div className="aa-subtle" style=${{marginTop:10}}>${posState.loading ? '加载中...' : '暂无数据'}</div>`}
                            </div>
                        </div>

                        <${CollapsibleSection}
                            title=${'🔍 路由探测'}
                            summary=${probeSummaryText()}
                            collapsedExtra=${html`
                                <div className="aa-row">
                                    <button className="aa-btn aa-btnBlue" onClick=${() => runProbe('forward')}>🔍 探测A→B</button>
                                    <button className="aa-btn aa-btnBlue" onClick=${() => runProbe('backward')}>🔍 探测B→A</button>
                                </div>
                            `}
                            defaultCollapsed=${false}
                        >
                            <div className="aa-grid2">
                                <div>
                                    <div className="aa-cardTitle" style=${{marginBottom: 10}}><span>A→B (Forward)</span></div>
                                    <div className="aa-row">
                                        <input className="aa-input aa-mono" value=${probeFwd.source} onChange=${e => setProbeFwd(s => ({...s, source: e.target.value}))} placeholder="source，如 binance 或 onchain:56" />
                                        <input className="aa-input aa-mono" value=${probeFwd.dest} onChange=${e => setProbeFwd(s => ({...s, dest: e.target.value}))} placeholder="dest，如 okex 或 onchain:1" />
                                        <input className="aa-input aa-mono" style=${{minWidth:90}} value=${probeFwd.amount} onChange=${e => setProbeFwd(s => ({...s, amount: e.target.value}))} placeholder="amount" />
                                        <button className="aa-btn aa-btnBlue" disabled=${probeFwd.loading} onClick=${() => runProbe('forward')}>🔍 搜索跨链</button>
                                        <button className="aa-btn aa-btnBlue" onClick=${() => window.openPipelineConfig && window.openPipelineConfig('forward')}>⚙ 配置Pipeline</button>
                                    </div>
                                    ${probeFwd.error ? html`<div className="aa-subtle" style=${{marginTop:10, color:'var(--aa-red)'}}>${probeFwd.error}</div>` : null}
                                    ${probeFwd.loading ? html`<div className="aa-subtle" style=${{marginTop:10}}>探测中...</div>` : null}
                                    ${(!probeFwd.loading && probeFwd.rows.length === 0) ? html`<div className="aa-subtle" style=${{marginTop:10}}>暂无探测结果。</div>` : null}
                                    ${probeFwd.rows.length > 0 ? html`
                                        <div className="aa-list">
                                            ${probeFwd.rows.map((row, idx) => html`
                                                <div key=${idx} className="aa-listItem">
                                                    <div className="aa-listMain">
                                                        <div className="aa-listTitle">${row.isRecommended ? '✅ 推荐' : '备选'} · ${fmtNum(row.totalTimeSec,0)}s · 损耗 ${row.totalFee != null ? row.totalFee : '--'}</div>
                                                        <div className="aa-listSub aa-mono">${Array.isArray(row.path) ? row.path.join(' → ') : '--'}</div>
                                                    </div>
                                                    <button className="aa-btn aa-btnBlue" onClick=${() => applyProbe('forward', row)}>应用</button>
                                                </div>
                                            `)}
                                        </div>
                                    ` : null}
                                </div>
                                <div>
                                    <div className="aa-cardTitle" style=${{marginBottom: 10}}><span>B→A (Backward)</span></div>
                                    <div className="aa-row">
                                        <input className="aa-input aa-mono" value=${probeBwd.source} onChange=${e => setProbeBwd(s => ({...s, source: e.target.value}))} placeholder="source，如 okex 或 onchain:1" />
                                        <input className="aa-input aa-mono" value=${probeBwd.dest} onChange=${e => setProbeBwd(s => ({...s, dest: e.target.value}))} placeholder="dest，如 binance 或 onchain:56" />
                                        <input className="aa-input aa-mono" style=${{minWidth:90}} value=${probeBwd.amount} onChange=${e => setProbeBwd(s => ({...s, amount: e.target.value}))} placeholder="amount" />
                                        <button className="aa-btn aa-btnBlue" disabled=${probeBwd.loading} onClick=${() => runProbe('backward')}>🔍 搜索跨链</button>
                                        <button className="aa-btn aa-btnBlue" onClick=${() => window.openPipelineConfig && window.openPipelineConfig('backward')}>⚙ 配置Pipeline</button>
                                    </div>
                                    ${hedgingCfg.error ? html`<div className="aa-subtle" style=${{marginTop:8, color:'var(--aa-red)'}}>QuoteAsset 获取失败：${hedgingCfg.error}</div>` : null}
                                    <div className="aa-subtle" style=${{marginTop:8}}>计价/提现资产：<span className="aa-mono">${hedgingCfg.quoteAsset || 'USDT'}</span></div>
                                    ${probeBwd.error ? html`<div className="aa-subtle" style=${{marginTop:10, color:'var(--aa-red)'}}>${probeBwd.error}</div>` : null}
                                    ${probeBwd.loading ? html`<div className="aa-subtle" style=${{marginTop:10}}>探测中...</div>` : null}
                                    ${(!probeBwd.loading && probeBwd.rows.length === 0) ? html`<div className="aa-subtle" style=${{marginTop:10}}>暂无探测结果。</div>` : null}
                                    ${probeBwd.rows.length > 0 ? html`
                                        <div className="aa-list">
                                            ${probeBwd.rows.map((row, idx) => html`
                                                <div key=${idx} className="aa-listItem">
                                                    <div className="aa-listMain">
                                                        <div className="aa-listTitle">${row.isRecommended ? '✅ 推荐' : '备选'} · ${fmtNum(row.totalTimeSec,0)}s · 损耗 ${row.totalFee != null ? row.totalFee : '--'}</div>
                                                        <div className="aa-listSub aa-mono">${Array.isArray(row.path) ? row.path.join(' → ') : '--'}</div>
                                                    </div>
                                                    <button className="aa-btn aa-btnBlue" onClick=${() => applyProbe('backward', row)}>应用</button>
                                                </div>
                                            `)}
                                        </div>
                                    ` : null}
                                </div>
                            </div>
                        </${CollapsibleSection}>

                        <${CollapsibleSection}
                            title=${'🛡 套保配置'}
                            summary=${(hedgingCfg.exchangeType ? '✅ ' : '⚠️ ') + (hedgingCfg.exchangeType || '未配置') + ' | ' + (hedgingCfg.hedgingSymbol || symbol || '--') + ' | Size:' + fmtNum(hedgingCfg.size, 0) + ' | 仓位:' + fmtNum(hedgingCfg.position, 0)}
                            defaultCollapsed=${false}
                        >
                            <div className="aa-row" style=${{marginTop: 2}}>
                                <select
                                    className="aa-input"
                                    value=${hedgingCfg.exchangeType}
                                    disabled=${hedgingCfg.loading || hedgeUi.saving}
                                    onChange=${e => setHedgingCfg(s => ({...s, exchangeType: e.target.value}))}
                                >
                                    <option value="binance">Binance</option>
                                    <option value="okex">OKX</option>
                                    <option value="bybit">Bybit</option>
                                    <option value="bitget">Bitget</option>
                                    <option value="gate">Gate</option>
                                </select>
                                <input
                                    className="aa-input aa-mono"
                                    style=${{minWidth: 220}}
                                    value=${hedgingCfg.hedgingSymbol}
                                    disabled=${hedgingCfg.loading || hedgeUi.saving}
                                    onChange=${e => setHedgingCfg(s => ({...s, hedgingSymbol: e.target.value}))}
                                    placeholder="Symbol"
                                />
                                <input
                                    className="aa-input aa-mono"
                                    style=${{minWidth: 140}}
                                    value=${String(hedgingCfg.size ?? '')}
                                    disabled=${hedgingCfg.loading || hedgeUi.saving}
                                    onChange=${e => setHedgingCfg(s => ({...s, size: Number(e.target.value)}))}
                                    placeholder="单次Size"
                                />
                                <button
                                    className="aa-btn aa-btnBlue"
                                    disabled=${hedgingCfg.loading || hedgeUi.saving}
                                    onClick=${async () => {
                                        setHedgeUi(s => ({...s, saving: true, error: ''}));
                                        try{
                                            const body = {
                                                symbol: symbol,
                                                enabled: true,
                                                exchangeType: hedgingCfg.exchangeType,
                                                hedgingSymbol: hedgingCfg.hedgingSymbol || symbol,
                                                size: Number(hedgingCfg.size) || 0,
                                                syncWithTriggerSize: !!hedgingCfg.syncWithTriggerSize,
                                                position: Number(hedgingCfg.position) || 0,
                                                autoWithdrawEnabled: !!hedgingCfg.autoWithdrawEnabled,
                                                autoWithdrawUseFixed: !!hedgingCfg.autoWithdrawUseFixed,
                                                autoWithdrawFixedSize: Number(hedgingCfg.autoWithdrawFixedSize) || 0,
                                                autoWithdrawPercentage: Number(hedgingCfg.autoWithdrawPercentage) || 0,
                                                quoteAsset: hedgingCfg.quoteAsset || 'USDT',
                                            };
                                            const r = await fetchJSON('/api/brick-moving/trigger/hedging', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
                                            if (!r.ok) {
                                                setHedgeUi(s => ({...s, saving: false, error: (r.data && r.data.error) || r.text || r.statusText}));
                                                return;
                                            }
                                            setHedgeUi(s => ({...s, saving: false, error: ''}));
                                            // 重新拉取一次，保证后端内存状态一致
                                            const rr = await fetchJSON('/api/brick-moving/trigger/hedging?triggerSymbol=' + encodeURIComponent(symbol));
                                            if (rr.ok && rr.data) {
                                                const d = rr.data;
                                                setHedgingCfg(s => ({...s,
                                                    loading:false, error:'',
                                                    enabled: d.enabled !== undefined ? !!d.enabled : true,
                                                    exchangeType: d.exchangeType || s.exchangeType,
                                                    hedgingSymbol: d.hedgingSymbol || s.hedgingSymbol,
                                                    size: (d.size != null ? Number(d.size) : s.size),
                                                    syncWithTriggerSize: d.syncWithTriggerSize !== undefined ? !!d.syncWithTriggerSize : s.syncWithTriggerSize,
                                                    position: (d.position != null ? Number(d.position) : s.position),
                                                    autoWithdrawEnabled: !!d.autoWithdrawEnabled,
                                                    autoWithdrawUseFixed: d.autoWithdrawUseFixed !== undefined ? !!d.autoWithdrawUseFixed : s.autoWithdrawUseFixed,
                                                    autoWithdrawFixedSize: (d.autoWithdrawFixedSize != null ? Number(d.autoWithdrawFixedSize) : s.autoWithdrawFixedSize),
                                                    autoWithdrawPercentage: (d.autoWithdrawPercentage != null ? Number(d.autoWithdrawPercentage) : s.autoWithdrawPercentage),
                                                    quoteAsset: (d.quoteAsset || s.quoteAsset || 'USDT'),
                                                }));
                                            }
                                        }catch(e){
                                            setHedgeUi(s => ({...s, saving: false, error: e.message || String(e)}));
                                        }
                                    }}
                                >
                                    {hedgeUi.saving ? '保存中...' : '保存'}
                                </button>
                            </div>
                            <div className="aa-row" style=${{marginTop: 12}}>
                                <label className="aa-subtle" style=${{display:'flex', alignItems:'center', gap:8}}>
                                    <input
                                        type="checkbox"
                                        checked=${!!hedgingCfg.syncWithTriggerSize}
                                        disabled=${hedgingCfg.loading || hedgeUi.saving}
                                        onChange=${e => setHedgingCfg(s => ({...s, syncWithTriggerSize: e.target.checked}))}
                                    />
                                    与Trigger Size同步
                                </label>
                                <input
                                    className="aa-input aa-mono"
                                    style=${{minWidth: 160}}
                                    value=${String(hedgingCfg.position ?? '')}
                                    disabled=${hedgingCfg.loading || hedgeUi.saving}
                                    onChange=${e => setHedgingCfg(s => ({...s, position: Number(e.target.value)}))}
                                    placeholder="总仓位"
                                />
                                <button
                                    className="aa-btn aa-btnGreen"
                                    disabled=${hedgeUi.opening || hedgingCfg.loading}
                                    onClick=${async () => {
                                        setHedgeUi(s => ({...s, opening: true, error: '', openMsg: ''}));
                                        try{
                                            const r = await fetchJSON('/api/brick-moving/trigger/open-position', {
                                                method:'POST',
                                                headers:{'Content-Type':'application/json'},
                                                body: JSON.stringify({ triggerSymbol: symbol })
                                            });
                                            if (!r.ok) {
                                                const errMsg = (r.data && r.data.error) || r.text || r.statusText;
                                                setHedgeUi(s => ({...s, opening:false, error: errMsg}));
                                                return;
                                            }
                                            const msg = (r.data && (r.data.msg || r.data.status)) ? (r.data.msg || r.data.status) : 'ok';
                                            setHedgeUi(s => ({...s, opening:false, openMsg: msg}));
                                            refreshPos();
                                        }catch(e){
                                            setHedgeUi(s => ({...s, opening:false, error: e.message || String(e)}));
                                        }
                                    }}
                                >
                                    {hedgeUi.opening ? '开仓中...' : '开仓'}
                                </button>
                            </div>
                            ${hedgingCfg.error ? html`<div className="aa-subtle" style=${{marginTop:10, color:'var(--aa-red)'}}>加载失败：${hedgingCfg.error}</div>` : null}
                            ${hedgeUi.error ? html`<div className="aa-subtle" style=${{marginTop:10, color:'var(--aa-red)'}}>${hedgeUi.error}</div>` : null}
                            ${hedgeUi.openMsg ? html`<div className="aa-subtle" style=${{marginTop:10, color:'var(--aa-green)'}}>${hedgeUi.openMsg}</div>` : null}
                        </${CollapsibleSection}>

                        <div className="aa-grid2">
                            <div className="aa-card">
                                <div className="aa-cardTitle"><span>💰 自动充提</span><span className="aa-subtle">常显</span></div>
                                <div className="aa-row" style=${{marginTop: 10}}>
                                    <select
                                        className="aa-input"
                                        value=${hedgingCfg.autoWithdrawUseFixed ? 'fixed' : 'percentage'}
                                        disabled=${autoUi.saving}
                                        onChange=${e => {
                                            const v = e.target.value;
                                            setHedgingCfg(s => ({...s, autoWithdrawUseFixed: v === 'fixed'}));
                                        }}
                                    >
                                        <option value="fixed">提币方式：固定Size</option>
                                        <option value="percentage">提币方式：按仓位百分比</option>
                                    </select>
                                    ${hedgingCfg.autoWithdrawUseFixed ? html`
                                        <input
                                            className="aa-input aa-mono"
                                            style=${{minWidth: 140}}
                                            value=${String(hedgingCfg.autoWithdrawFixedSize ?? '')}
                                            disabled=${autoUi.saving}
                                            onChange=${e => setHedgingCfg(s => ({...s, autoWithdrawFixedSize: Number(e.target.value)}))}
                                            placeholder="固定Size"
                                        />
                                    ` : html`
                                        <input
                                            className="aa-input aa-mono"
                                            style=${{minWidth: 140}}
                                            value=${String(hedgingCfg.autoWithdrawPercentage ?? '')}
                                            disabled=${autoUi.saving}
                                            onChange=${e => setHedgingCfg(s => ({...s, autoWithdrawPercentage: Number(e.target.value)}))}
                                            placeholder="百分比(0-1)"
                                        />
                                    `}
                                    <button
                                        className="aa-btn aa-btnBlue"
                                        disabled=${autoUi.saving}
                                        onClick=${() => saveHedgingAll({ autoWithdrawEnabled: true })}
                                    >启用并保存</button>
                                </div>
                                ${autoUi.error ? html`<div className="aa-subtle" style=${{marginTop:10, color:'var(--aa-red)'}}>${autoUi.error}</div>` : null}

                                <div className="aa-divider"></div>
                                <div className="aa-row">
                                    ${autoRunning.forward ? html`
                                        <button className="aa-btn aa-btnRed" onClick=${() => stopAuto('forward')}>停止自动充提 A→B</button>
                                    ` : html`
                                        <button className="aa-btn aa-btnGreen" onClick=${() => startAuto('forward')}>自动检测并提币 A→B</button>
                                    `}
                                    ${autoRunning.backward ? html`
                                        <button className="aa-btn aa-btnRed" onClick=${() => stopAuto('backward')}>停止自动充提 B→A</button>
                                    ` : html`
                                        <button className="aa-btn aa-btnGreen" onClick=${() => startAuto('backward')}>自动检测并提币 B→A</button>
                                    `}
                                </div>
                                <div className="aa-subtle" style=${{marginTop:10}}>
                                    ${autoUi.last.forward ? html`<div>Forward：${autoUi.last.forward.ok ? 'balance=' + fmtNum(autoUi.last.forward.balance, 6) + ' ' + (autoUi.last.forward.balanceAsset || '') + ' threshold=' + fmtNum(autoUi.last.forward.threshold, 6) : ('error=' + (autoUi.last.forward.error || '--'))}</div>` : null}
                                    ${autoUi.last.backward ? html`<div>Backward：${autoUi.last.backward.ok ? 'balance=' + fmtNum(autoUi.last.backward.balance, 6) + ' ' + (autoUi.last.backward.balanceAsset || '') + ' threshold=' + fmtNum(autoUi.last.backward.threshold, 6) : ('error=' + (autoUi.last.backward.error || '--'))}</div>` : null}
                                </div>
                            </div>
                            <div className="aa-card">
                                <div className="aa-cardTitle"><span>🔄 链上Swap并广播</span><span className="aa-subtle">常显</span></div>
                                <div className="aa-row" style=${{marginTop: 10}}>
                                    <input
                                        className="aa-input aa-mono"
                                        style=${{minWidth: 160}}
                                        value=${swapUi.amount}
                                        disabled=${swapUi.loading}
                                        onChange=${e => setSwapUi(s => ({...s, amount: e.target.value}))}
                                        placeholder="数量"
                                    />
                                    <select className="aa-input" value=${swapUi.direction} disabled=${swapUi.loading} onChange=${e => setSwapUi(s => ({...s, direction: e.target.value}))}>
                                        <option value="buy">买入USDT→代币</option>
                                        <option value="sell">卖出</option>
                                    </select>
                                    <select className="aa-input" value=${swapUi.source} disabled=${swapUi.loading} onChange=${e => setSwapUi(s => ({...s, source: e.target.value}))}>
                                        <option value="A">Source A</option>
                                        <option value="B">Source B</option>
                                    </select>
                                    <button
                                        className="aa-btn aa-btnGreen"
                                        disabled=${swapUi.loading || !swapUi.amount}
                                        onClick=${async () => {
                                            setSwapUi(s => ({...s, loading:true, error:'', txHash:''}));
                                            try{
                                                const body = { triggerSymbol: symbol, amount: swapUi.amount, direction: swapUi.direction, source: swapUi.source };
                                                const r = await fetchJSON('/api/brick-moving/trigger/swap', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
                                                if (!r.ok) {
                                                    setSwapUi(s => ({...s, loading:false, error: (r.data && r.data.error) || r.text || r.statusText }));
                                                    return;
                                                }
                                                const tx = (r.data && r.data.txHash) ? r.data.txHash : '';
                                                setSwapUi(s => ({...s, loading:false, txHash: tx, error:''}));
                                            }catch(e){
                                                setSwapUi(s => ({...s, loading:false, error: e.message || String(e)}));
                                            }
                                        }}
                                    >执行 Swap 并广播</button>
                                </div>
                                ${swapUi.error ? html`<div className="aa-subtle" style=${{marginTop:10, color:'var(--aa-red)'}}>${swapUi.error}</div>` : null}
                                ${swapUi.txHash ? html`<div className="aa-subtle aa-mono" style=${{marginTop:10, color:'var(--aa-green)'}}>txHash: ${swapUi.txHash}</div>` : null}
                            </div>
                        </div>

                        <div className="aa-stack">
                            <div className="aa-card">
                                <div className="aa-cardTitle">
                                    <span>+A-B (Forward)</span>
                                    <span className="aa-row" style=${{gap:8}}>
                                        <span className=${'aa-dot ' + (triggerState.enabledAB ? 'aa-dotRunning' : 'aa-dotStopped')}></span>
                                        <span className="aa-subtle">${triggerState.enabledAB ? '运行中' : '已停止'}</span>
                                    </span>
                                </div>
                                <div className="aa-row" style=${{marginTop:10}}>
                                    <span className="aa-subtle">📈 当前价差：</span>
                                    <span className="aa-mono" style=${{color: (priceDiff.diffAB != null && priceDiff.diffAB >= 0) ? 'var(--aa-green)' : 'var(--aa-red)'}}>
                                        ${priceDiff.exists && priceDiff.diffAB != null ? (fmtNum(priceDiff.diffAB, 4) + '%') : '--'}
                                    </span>
                                    ${priceDiff.error ? html`<span className="aa-subtle" style=${{color:'var(--aa-red)'}}>(${priceDiff.error})</span>` : null}
                                </div>
                                <div className="aa-row" style=${{marginTop: 10}}>
                                    <input className="aa-input aa-mono" disabled=${triggerState.enabledAB} value=${String(triggerState.thresholdAB)} onChange=${e => setTriggerState(s => ({...s, thresholdAB: Number(e.target.value)}))} placeholder="触发阈值" />
                                    <input className="aa-input aa-mono" disabled=${triggerState.enabledAB} value=${String(triggerState.size)} onChange=${e => setTriggerState(s => ({...s, size: Number(e.target.value)}))} placeholder="Size" />
                                </div>
                                <div className="aa-sepLabel">─── 链上 ───</div>
                                <div className="aa-row">
                                    <input className="aa-input aa-mono" disabled=${triggerState.enabledAB} value=${String(triggerState.onChainSlippage)} onChange=${e => setTriggerState(s => ({...s, onChainSlippage: e.target.value}))} placeholder="滑点%" />
                                    <input className="aa-input aa-mono" disabled=${triggerState.enabledAB} value=${String(triggerState.gasLimit)} onChange=${e => setTriggerState(s => ({...s, gasLimit: e.target.value}))} placeholder="GasLimit" />
                                    <input className="aa-input aa-mono" disabled=${triggerState.enabledAB} value=${String(triggerState.gasMultiplier)} onChange=${e => setTriggerState(s => ({...s, gasMultiplier: Number(e.target.value)}))} placeholder="Gas倍数x" />
                                </div>
                                <div className="aa-row" style=${{marginTop: 12}}>
                                    <button className="aa-btn aa-btnGreen" disabled=${triggerState.enabledAB} onClick=${() => updateTriggerConfig({
                                        size: Number(triggerState.size) || 0,
                                        thresholdAB: Number(triggerState.thresholdAB) || 0,
                                        onChainSlippageA: String(triggerState.onChainSlippage || ''),
                                        onChainSlippageB: String(triggerState.onChainSlippage || ''),
                                        gasMultiplierA: Number(triggerState.gasMultiplier) || 1,
                                        gasMultiplierB: Number(triggerState.gasMultiplier) || 1,
                                        onChainGasLimitA: String(triggerState.gasLimit || ''),
                                        onChainGasLimitB: String(triggerState.gasLimit || ''),
                                        enabledAB: true,
                                    })}>🚀 启动+A-B</button>
                                    <button className="aa-btn aa-btnRed" disabled=${!triggerState.enabledAB} onClick=${() => updateTriggerConfig({ enabledAB: false })}>⏹ 停止</button>
                                </div>
                                ${triggerState.error ? html`<div className="aa-subtle" style=${{marginTop:10, color:'var(--aa-red)'}}>加载/同步失败：${triggerState.error}</div>` : null}
                            </div>

                            <${CollapsibleSection}
                                title=${html`<span className="aa-row" style=${{gap:10}}><span>-A+B (Backward)</span><span className=${'aa-dot ' + (triggerState.enabledBA ? 'aa-dotRunning' : 'aa-dotStopped')}></span><span className="aa-subtle">${triggerState.enabledBA ? '运行中' : '已停止'}</span></span>`}
                                summary=${'📈 价差: ' + (priceDiff.exists && priceDiff.diffBA != null ? (fmtNum(priceDiff.diffBA, 4) + '%') : '--') +
                                    ' │ 阈值: ' + fmtNum(triggerState.thresholdBA, 4) +
                                    ' │ Size: ' + fmtNum(triggerState.size, 0) +
                                    ' │ 滑点: ' + String(triggerState.onChainSlippage || '--') + '%'}
                                defaultCollapsed=${true}
                            >
                                <div className="aa-row" style=${{marginTop:10}}>
                                    <span className="aa-subtle">📈 当前价差：</span>
                                    <span className="aa-mono" style=${{color: (priceDiff.diffBA != null && priceDiff.diffBA >= 0) ? 'var(--aa-green)' : 'var(--aa-red)'}}>
                                        ${priceDiff.exists && priceDiff.diffBA != null ? (fmtNum(priceDiff.diffBA, 4) + '%') : '--'}
                                    </span>
                                </div>
                                <div className="aa-row" style=${{marginTop: 10}}>
                                    <input className="aa-input aa-mono" disabled=${triggerState.enabledBA} value=${String(triggerState.thresholdBA)} onChange=${e => setTriggerState(s => ({...s, thresholdBA: Number(e.target.value)}))} placeholder="触发阈值" />
                                    <input className="aa-input aa-mono" disabled=${triggerState.enabledBA} value=${String(triggerState.size)} onChange=${e => setTriggerState(s => ({...s, size: Number(e.target.value)}))} placeholder="Size" />
                                </div>
                                <div className="aa-sepLabel">─── 链上 ───</div>
                                <div className="aa-row">
                                    <input className="aa-input aa-mono" disabled=${triggerState.enabledBA} value=${String(triggerState.onChainSlippage)} onChange=${e => setTriggerState(s => ({...s, onChainSlippage: e.target.value}))} placeholder="滑点%" />
                                    <input className="aa-input aa-mono" disabled=${triggerState.enabledBA} value=${String(triggerState.gasLimit)} onChange=${e => setTriggerState(s => ({...s, gasLimit: e.target.value}))} placeholder="GasLimit" />
                                    <input className="aa-input aa-mono" disabled=${triggerState.enabledBA} value=${String(triggerState.gasMultiplier)} onChange=${e => setTriggerState(s => ({...s, gasMultiplier: Number(e.target.value)}))} placeholder="Gas倍数x" />
                                </div>
                                <div className="aa-row" style=${{marginTop: 12}}>
                                    <button className="aa-btn aa-btnGreen" disabled=${triggerState.enabledBA} onClick=${() => updateTriggerConfig({
                                        size: Number(triggerState.size) || 0,
                                        thresholdBA: Number(triggerState.thresholdBA) || 0,
                                        onChainSlippageA: String(triggerState.onChainSlippage || ''),
                                        onChainSlippageB: String(triggerState.onChainSlippage || ''),
                                        gasMultiplierA: Number(triggerState.gasMultiplier) || 1,
                                        gasMultiplierB: Number(triggerState.gasMultiplier) || 1,
                                        onChainGasLimitA: String(triggerState.gasLimit || ''),
                                        onChainGasLimitB: String(triggerState.gasLimit || ''),
                                        enabledBA: true,
                                    })}>🚀 启动-A+B</button>
                                    <button className="aa-btn aa-btnRed" disabled=${!triggerState.enabledBA} onClick=${() => updateTriggerConfig({ enabledBA: false })}>⏹ 停止</button>
                                </div>
                            </${CollapsibleSection}>
                        </div>
                    </div>
                `;
            }

            const rootEl = document.getElementById('app');
            if (!rootEl) return;
            ReactDOM.createRoot(rootEl).render(html`<${App} />`);
        })();
    </script>
</body>
</html>
