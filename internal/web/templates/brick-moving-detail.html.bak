        }
        
        // 停止Trigger
        async function stopTrigger() {
            try {
                const res = await fetch('/api/brick-moving/trigger/stop?symbol=' + encodeURIComponent(currentSymbol), { method: 'POST' });
                if (res.ok) {
                    alert('Trigger 已停止');
                    loadTriggerDetail();
