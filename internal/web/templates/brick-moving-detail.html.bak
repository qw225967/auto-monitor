                '<label>固定提币 Size (留空则使用单次交易 Size)</label>' +
                '<input type="number" id="autoWithdrawFixedSize" value="' + (hedgingData.autoWithdrawFixedSize || '') + '" step="0.01" placeholder="留空使用单次交易 Size" onchange="autoSaveHedgingConfig()">' +
                '</div>' +
                '<div class="config-form-item" id="autoWithdrawPercentageContainer" style="display:' + (!hedgingData.autoWithdrawUseFixed ? 'block' : 'none') + ';">' +
                '<label>仓位百分比 (0-1)</label>' +
                '<input type="number" id="autoWithdrawPercentage" value="' + (hedgingData.autoWithdrawPercentage || '0') + '" step="0.01" min="0" max="1" placeholder="0.5" onchange="autoSaveHedgingConfig()">' +
