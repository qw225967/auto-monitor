                '<option value="bitget"' + (hedgingData.exchangeType === 'bitget' ? ' selected' : '') + '>Bitget</option>' +
                '<option value="okex"' + (hedgingData.exchangeType === 'okex' ? ' selected' : '') + '>OKX</option>' +
                '</select>' +
                '</div>' +
                '<div class="config-form-item">' +
                '<label>套保 Symbol</label>' +
