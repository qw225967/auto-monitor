                '<button class="btn-danger" id="btnStopAutoWithdrawBackward" onclick="stopAutoDetectWithdraw(\'backward\')" style="width: 100%; padding: 8px; display: none;">停止自动充提 (B→A)</button>' +
                '</div>' +
                '<div class="config-status" id="hedgingStatus" style="margin-bottom:8px; margin-top: 10px;"></div>' +
