        // 更新价差
        let priceDiffUpdateInterval = null;
        async function updatePriceDiff() {
            if (!currentSymbol) return;
            try {
                const res = await fetch('/api/brick-moving/trigger/price-diff?triggerSymbol=' + encodeURIComponent(currentSymbol));
                if (res.ok) {
                    const data = await res.json();
                    const diffABEl = document.getElementById('triggerDiffAB');
                    const diffBAEl = document.getElementById('triggerDiffBA');
                    if (diffABEl) {
                        if (data.exists && data.diffAB != null) {
                            diffABEl.textContent = data.diffAB.toFixed(4) + '%';
                            diffABEl.style.color = data.diffAB >= 0 ? '#4ade80' : '#f43f5e';
                        } else {
                            diffABEl.textContent = '--';
                            diffABEl.style.color = '#888';
                        }
                    }
                    if (diffBAEl) {
                        if (data.exists && data.diffBA != null) {
                            diffBAEl.textContent = data.diffBA.toFixed(4) + '%';
                            diffBAEl.style.color = data.diffBA >= 0 ? '#4ade80' : '#f43f5e';
                        } else {
                            diffBAEl.textContent = '--';
                            diffBAEl.style.color = '#888';
                        }
                    }
                }
            } catch (error) {
                console.error('更新价差失败:', error);
            }
        }
        
        function startPriceDiffUpdate() {
            if (priceDiffUpdateInterval) {
                clearInterval(priceDiffUpdateInterval);
            }
            updatePriceDiff(); // 立即更新一次
            priceDiffUpdateInterval = setInterval(updatePriceDiff, 2000); // 每2秒更新一次
        }
        
