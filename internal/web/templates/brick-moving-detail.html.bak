                '<label>与 Trigger Size 同步</label>' +
                '<input type="checkbox" id="hedgingSyncSize" ' + (hedgingData.syncWithTriggerSize ? 'checked' : '') + ' onchange="autoSaveHedgingConfig()">' +
                '</div>' +
                '<div class="config-form-item">' +
                '<label>总仓位</label>' +
                '<input type="number" id="hedgingPosition" value="' + hedgingData.position + '" step="0.01" placeholder="0" onchange="autoSaveHedgingConfig()">' +
                '</div>' +
                '</div>' +
                '<button class="btn-primary" onclick="openPosition()" style="margin-top: 10px; width: 100%;">开仓</button>' +
                '<div id="hedgingPositionBox" style="margin-top: 10px; padding: 10px; background: #1a2e1a; border: 1px solid #4ade80; border-radius: 4px; font-size: 12px; min-height: 40px;">加载套保仓位...</div>' +
                '<div class="config-section-title" style="margin-top: 16px;">🔀 链上直接 Swap 并广播</div>' +
                '<div class="config-form" style="margin-top: 8px;">' +
                '<div class="config-form-item"><label>数量 (Amount)</label><input type="text" id="swapAmount" placeholder="例如 100" value=""></div>' +
                '<div class="config-form-item"><label>方向</label><select id="swapDirection"><option value="buy">买入 (USDT→代币)</option><option value="sell">卖出 (代币→USDT)</option></select></div>' +
                '<div class="config-form-item"><label>端</label><select id="swapSource"><option value="A">Source A</option><option value="B">Source B</option></select></div>' +
                '<button class="btn-primary" onclick="triggerSwap()" style="width: 100%; margin-top: 8px;">执行 Swap 并广播</button>' +
                '<div id="swapResult" style="margin-top: 8px; font-size: 12px; color: #888;"></div>' +
                '</div>' +
                '</div>' +
                
                // 自动充提大小配置区域
                '<div class="config-section">' +
                '<div class="config-section-title">💸 自动充提大小</div>' +
                '<div class="config-form">' +
                '<div class="config-form-item">' +
                '<label>提币方式</label>' +
                '<select id="autoWithdrawMode" onchange="toggleAutoWithdrawMode(); autoSaveHedgingConfig();">' +
