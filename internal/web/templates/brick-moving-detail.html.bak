                '<div class="config-section-title">🔍 路由探测</div>' +
                '<div style="margin-top: auto; display: flex; flex-direction: column; gap: 10px;">' +
                '<button class="btn-secondary" onclick="openChainSearch(\'forward\')" style="width: 100%; padding: 8px;">🔍 搜索充提链 (A→B)</button>' +
                '<button class="btn-secondary" onclick="openChainSearch(\'backward\')" style="width: 100%; padding: 8px;">🔍 搜索充提链 (B→A)</button>' +
                '<button class="btn-secondary" onclick="openPipelineConfig(\'forward\')" style="width: 100%; padding: 8px;">配置 Forward Pipeline (A → B)</button>' +
                '<button class="btn-secondary" onclick="openPipelineConfig(\'backward\')" style="width: 100%; padding: 8px;">配置 Backward Pipeline (B → A)</button>' +
                '<div id="routeProbeCandidatesBox" style="margin-top: 15px;"></div>' +
                '</div>' +
                '</div>' +
                
                // 2. Trigger 配置区域
                '<div class="config-section">' +
                '<div class="config-section-title">⚙️ Trigger 配置</div>' +
                '<div class="config-form">' +
                '<div class="config-form-item">' +
                '<label>Size</label>' +
                '<input type="number" id="triggerSize" value="' + (trigger.size || '1000') + '" ' +
                'onchange="updateTriggerConfig()" step="0.01" placeholder="1000">' +
                '</div>' +
                '<div class="config-form-item">' +
                '<label>+A-B 阈值</label>' +
                '<input type="number" id="triggerThresholdAB" value="' + (trigger.thresholdAB !== undefined && trigger.thresholdAB !== null ? trigger.thresholdAB : (trigger.minInterval || '0.2')) + '" ' +
                'onchange="updateTriggerConfig()" step="0.0001" placeholder="0.2">' +
                '</div>' +
                '<div class="config-form-item">' +
                '<label>-A+B 阈值</label>' +
                '<input type="number" id="triggerThresholdBA" value="' + (trigger.thresholdBA !== undefined && trigger.thresholdBA !== null ? trigger.thresholdBA : (trigger.maxInterval || '0')) + '" ' +
                'onchange="updateTriggerConfig()" step="0.0001" placeholder="0">' +
                '</div>' +
                '<div class="config-form-item">' +
                '<label>触发方向 +A-B</label>' +
                '<div style="display: flex; align-items: center; justify-content: space-between; padding: 8px; background: #2a2a2a; border-radius: 4px; margin-top: 5px;">' +
                '<div style="flex: 1;">' +
                '<div style="font-size: 12px; color: #888; margin-bottom: 4px;">实时价差</div>' +
                '<div id="triggerDiffAB" style="font-size: 16px; font-weight: bold; color: #4ade80;">--</div>' +
                '</div>' +
                '<div style="display: flex; gap: 8px;">' +
                '<button class="btn-primary" onclick="startTriggerDirectionAB()" id="btnStartAB" style="font-size: 12px; padding: 6px 12px;">开始</button>' +
                '<button class="btn-danger" onclick="stopTriggerDirectionAB()" id="btnStopAB" style="font-size: 12px; padding: 6px 12px;">停止</button>' +
                '</div>' +
                '</div>' +
                '</div>' +
                '<div class="config-form-item">' +
                '<label>触发方向 -A+B</label>' +
                '<div style="display: flex; align-items: center; justify-content: space-between; padding: 8px; background: #2a2a2a; border-radius: 4px; margin-top: 5px;">' +
                '<div style="flex: 1;">' +
                '<div style="font-size: 12px; color: #888; margin-bottom: 4px;">实时价差</div>' +
                '<div id="triggerDiffBA" style="font-size: 16px; font-weight: bold; color: #4ade80;">--</div>' +
                '</div>' +
                '<div style="display: flex; gap: 8px;">' +
                '<button class="btn-primary" onclick="startTriggerDirectionBA()" id="btnStartBA" style="font-size: 12px; padding: 6px 12px;">开始</button>' +
                '<button class="btn-danger" onclick="stopTriggerDirectionBA()" id="btnStopBA" style="font-size: 12px; padding: 6px 12px;">停止</button>' +
                '</div>' +
                '</div>' +
                '</div>' +
                '</div>' +
                '</div>' +
                
                // 链上配置：滑点、Gas 乘数、Gas Limit（当 A 或 B 为链上时显示）
                (function() {
                    var isAOnchain = trigger.traderAType && String(trigger.traderAType).indexOf('onchain') === 0;
                    var isBOnchain = trigger.traderBType && String(trigger.traderBType).indexOf('onchain') === 0;
                    if (!isAOnchain && !isBOnchain) return '';
                    var out = '<div class="config-section">' +
                        '<div class="config-section-title">⛽ 链上配置（滑点 / Gas 倍数 / Gas Limit）</div>' +
                        '<div class="config-form">';
                    if (isAOnchain) {
                        out += '<div style="margin-bottom: 15px; padding: 10px; background: #1a2a2a; border-radius: 4px; border-left: 3px solid #4ade80;">' +
                            '<div style="font-weight: bold; color: #4ade80; margin-bottom: 10px;">Source A（链上）</div>' +
                            '<div class="config-form-item"><label>滑点 (%)</label>' +
                            '<input type="text" id="onChainSlippageA" value="' + (trigger.onChainSlippageA != null ? String(trigger.onChainSlippageA) : '0.2') + '" placeholder="0.2" onchange="updateTriggerConfig()"></div>' +
                            '<div class="config-form-item"><label>Gas 乘数</label>' +
                            '<input type="number" id="gasMultiplierA" value="' + (trigger.gasMultiplierA != null ? trigger.gasMultiplierA : '1') + '" step="0.1" min="1" placeholder="1" onchange="updateTriggerConfig()"></div>' +
                            '<div class="config-form-item"><label>Gas Limit</label>' +
                            '<input type="text" id="onChainGasLimitA" value="' + (trigger.onChainGasLimitA != null ? String(trigger.onChainGasLimitA) : '500000') + '" placeholder="500000" onchange="updateTriggerConfig()"></div>' +
                            '</div>';
                    }
                    if (isBOnchain) {
                        out += '<div style="margin-bottom: 15px; padding: 10px; background: #1a2a2a; border-radius: 4px; border-left: 3px solid #4ade80;">' +
                            '<div style="font-weight: bold; color: #4ade80; margin-bottom: 10px;">Source B（链上）</div>' +
                            '<div class="config-form-item"><label>滑点 (%)</label>' +
                            '<input type="text" id="onChainSlippageB" value="' + (trigger.onChainSlippageB != null ? String(trigger.onChainSlippageB) : '0.2') + '" placeholder="0.2" onchange="updateTriggerConfig()"></div>' +
                            '<div class="config-form-item"><label>Gas 乘数</label>' +
                            '<input type="number" id="gasMultiplierB" value="' + (trigger.gasMultiplierB != null ? trigger.gasMultiplierB : '1') + '" step="0.1" min="1" placeholder="1" onchange="updateTriggerConfig()"></div>' +
                            '<div class="config-form-item"><label>Gas Limit</label>' +
                            '<input type="text" id="onChainGasLimitB" value="' + (trigger.onChainGasLimitB != null ? String(trigger.onChainGasLimitB) : '500000') + '" placeholder="500000" onchange="updateTriggerConfig()"></div>' +
                            '</div>';
                    }
                    out += '</div></div>';
                    return out;
                })() +
                
                '</div>';
            
            console.log('生成的HTML长度:', html.length);
            const container = document.getElementById('configSectionsContainer');
            if (!container) {
                console.error('找不到configSectionsContainer元素');
                return;
            }
            container.innerHTML = html;
            console.log('配置区域已渲染完成');
        }
        
        // 渲染 Pipeline 可视化（含「应用」按钮，将已配置 pipeline 设为当前生效）
        function renderPipelineVisual(pipelines) {
            if (!pipelines || (!pipelines.forward && !pipelines.backward)) {
                return '<div style="color: #666; width: 100%; text-align: center;">暂无 Pipeline 配置</div>';
            }
            
            function edgeBridgeProtocol(edges, fromIdx, toIdx) {
                if (!edges || !edges.length) return '';
                for (let i = 0; i < edges.length; i++) {
                    const e = edges[i];
                    const f = e.from != null ? Number(e.from) : i;
                    const t = e.to != null ? Number(e.to) : i + 1;
                    if (f === fromIdx && t === toIdx && e.bridgeProtocol) return e.bridgeProtocol;
                }
                return '';
            }
            let html = '';
            if (pipelines.forward && pipelines.forward.nodes && pipelines.forward.nodes.length > 0) {
                const fwdEdges = pipelines.forward.edges || [];
                html += '<div style="width: 100%; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">';
                html += '<strong style="color: #4ade80;">Forward (A → B):</strong>';
                html += '<button class="btn-primary" onclick="applyPipelineConfig(\'forward\')" style="padding: 4px 10px; font-size: 12px;">应用</button>';
                html += '</div>';
                html += '<div style="display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">';
                pipelines.forward.nodes.forEach((node, idx) => {
                    if (idx > 0) {
                        const proto = edgeBridgeProtocol(fwdEdges, idx - 1, idx);
                        html += '<span class="pipeline-arrow">→</span>';
                        if (proto) html += '<span style="font-size: 11px; color: #60a5fa;" title="跨链协议">[' + proto + ']</span>';
                    }
                    html += '<span class="pipeline-node">' + (node.name || node.exchangeType || node.chainName || node.type) + '</span>';
                });
                html += '</div>';
            }
            
            if (pipelines.backward && pipelines.backward.nodes && pipelines.backward.nodes.length > 0) {
                const bakEdges = pipelines.backward.edges || [];
                html += '<div style="width: 100%; margin-top: 15px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">';
                html += '<strong style="color: #4ade80;">Backward (B → A):</strong>';
                html += '<button class="btn-primary" onclick="applyPipelineConfig(\'backward\')" style="padding: 4px 10px; font-size: 12px;">应用</button>';
                html += '</div>';
                html += '<div style="display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">';
                pipelines.backward.nodes.forEach((node, idx) => {
                    if (idx > 0) {
                        const proto = edgeBridgeProtocol(bakEdges, idx - 1, idx);
                        html += '<span class="pipeline-arrow">→</span>';
                        if (proto) html += '<span style="font-size: 11px; color: #60a5fa;" title="跨链协议">[' + proto + ']</span>';
                    }
                    html += '<span class="pipeline-node">' + (node.name || node.exchangeType || node.chainName || node.type) + '</span>';
                });
                html += '</div>';
            }
            
            return html || '<div style="color: #666; width: 100%; text-align: center;">暂无 Pipeline 配置</div>';
        }
        
        async function openPosition() {
            if (!currentSymbol) return;
            if (!confirm('确定开仓？将在 A 交易所买入现货，同时在套保所同步做空相同数量合约。')) return;
            try {
                const res = await fetch('/api/brick-moving/trigger/open-position', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ triggerSymbol: currentSymbol })
                });
                const text = await res.text();
                let data = {};
                try { data = JSON.parse(text); } catch (e) { if (text) data = { error: text }; }
                if (res.ok && (data.status === 'ok' || data.msg)) {
                    alert(data.msg || '开仓已提交');
                    loadHedgingPosition();
                } else {
                    alert('开仓失败: ' + (data.error || res.statusText));
                }
            } catch (e) {
                alert('开仓失败: ' + e.message);
            }
        }
        
        async function triggerSwap() {
            if (!currentSymbol) return;
            const amount = (document.getElementById('swapAmount') || {}).value?.trim();
            if (!amount) { alert('请输入数量 (Amount)'); return; }
            const direction = (document.getElementById('swapDirection') || {}).value || 'buy';
            const source = (document.getElementById('swapSource') || {}).value || 'A';
            const resultEl = document.getElementById('swapResult');
            if (resultEl) resultEl.textContent = '提交中...';
            try {
                const res = await fetch('/api/brick-moving/trigger/swap', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ triggerSymbol: currentSymbol, amount, direction, source })
                });
                const text = await res.text();
                let data = {};
                try { data = JSON.parse(text); } catch (e) { if (text) data = { error: text }; }
                if (res.ok && (data.status === 'ok')) {
                    if (resultEl) resultEl.innerHTML = '成功。txHash: <code style="word-break:break-all;">' + (data.txHash || '') + '</code>';
                    if (data.txHash) alert('Swap 已广播，txHash: ' + data.txHash);
                } else {
                    if (resultEl) resultEl.textContent = '失败: ' + (data.error || res.statusText);
                    alert('Swap 失败: ' + (data.error || res.statusText));
                }
            } catch (e) {
                if (resultEl) resultEl.textContent = '请求异常: ' + e.message;
                alert('请求异常: ' + e.message);
            }
        }
        
        async function loadHedgingPosition() {
            const boxEl = document.getElementById('hedgingPositionBox');
            const hedgingEl = document.getElementById('hedgingPositionDisplay');
            const aEl = document.getElementById('aPositionDisplay');
            const bEl = document.getElementById('bPositionDisplay');
            try {
                const res = await fetch('/api/brick-moving/trigger/hedging-position?triggerSymbol=' + encodeURIComponent(currentSymbol));
                const data = await res.json().catch(() => ({}));
                if (boxEl) {
                    let html = '';
                    if (data.margin !== undefined && data.margin !== '') html += '保证金: ' + data.margin + '<br/>';
                    if (data.maxProfit !== undefined && data.maxProfit !== '') html += '最大盈利: ' + data.maxProfit + '<br/>';
                    if (data.riskParams && Object.keys(data.riskParams || {}).length) html += '风控: ' + JSON.stringify(data.riskParams) + '<br/>';
                    if (data.positions && data.positions.length) {
                        html += '持仓: ';
                        data.positions.forEach(p => {
                            html += (p.exchange_type || p.exchangeType || '') + ' ' + (p.symbol || '') + ' ' + (p.size != null ? p.size : p.balance) + '; ';
                        });
                    }
                    if (data.onchain && data.onchain.length) {
                        html += '链上: ';
                        data.onchain.forEach(o => { html += (o.chain_id || o.chainId || o.chain_index || '') + ' ' + (o.balance != null ? o.balance : '') + '; '; });
                    }
                    boxEl.innerHTML = html || '暂无套保仓位数据';
                }
                var fmt4 = function(v) { return (v != null && !isNaN(v) ? parseFloat(v) : 0).toFixed(4); };
                var fmt2 = function(v) { return (v != null && !isNaN(v) ? parseFloat(v) : 0).toFixed(2); };
                if (hedgingEl) hedgingEl.innerHTML = '开仓: ' + fmt4(data.hedgingPosition) + '<br/>USDT: ' + fmt2(data.hedgingPositionUsdt);
                var gasLine = function(tok, bal) { return (tok && (bal != null && !isNaN(bal))) ? '<br/>Gas ' + tok + ': ' + parseFloat(bal).toFixed(6) : ''; };
                if (aEl) aEl.innerHTML = '币: ' + fmt4(data.aPositionCoin) + '<br/>USDT: ' + fmt2(data.aPositionUsdt) + gasLine(data.aPositionGasToken, data.aPositionGasBalance);
                if (bEl) bEl.innerHTML = '币: ' + fmt4(data.bPositionCoin) + '<br/>USDT: ' + fmt2(data.bPositionUsdt) + gasLine(data.bPositionGasToken, data.bPositionGasBalance);
                var onchainGasContainer = document.getElementById('onchainGasContainer');
                var onchainGasEl = document.getElementById('onchainGasDisplay');
                if (onchainGasContainer && onchainGasEl && data.onchainGasChain) {
                    onchainGasContainer.style.display = 'block';
                    onchainGasEl.innerHTML = '链(' + data.onchainGasChain + ') Gas ' + (data.onchainGasToken || '') + ': ' + fmt4(data.onchainGasBalance);
                } else if (onchainGasContainer) {
                    onchainGasContainer.style.display = 'none';
                }
                // 渲染中间链持仓
                var midContainer = document.getElementById('intermediatePositionsContainer');
                if (midContainer) {
                    var midPositions = data.intermediatePositions || [];
                    if (midPositions.length > 0) {
                        var midHtml = '';
                        midPositions.forEach(function(mp) {
                            var label = '中间链(' + (mp.chainName || mp.chainId) + ')';
                            var coinStr = fmt4(mp.coin);
                            var gasStr = (mp.gasToken && mp.gasBalance != null) ? ('<br/>Gas ' + mp.gasToken + ': ' + parseFloat(mp.gasBalance || 0).toFixed(6)) : '';
                            midHtml += '<div class="position-item"><label class="position-label">' + label + '</label><div class="position-display">币: ' + coinStr + gasStr + '</div></div>';
                        });
                        midContainer.innerHTML = midHtml;
                    } else {
                        midContainer.innerHTML = '';
                    }
                }
            } catch (e) {
                if (boxEl) boxEl.innerHTML = '加载失败: ' + e.message;
            }
        }
        
        let withdrawHistoryPollInterval = null;
        
        async function loadWithdrawHistory() {
            const el = document.getElementById('withdrawHistoryList');
            const vizEl = document.getElementById('withdrawPipelineViz');
            if (!el || !currentSymbol) return;
            try {
                const res = await fetch('/api/brick-moving/withdraw-history?triggerSymbol=' + encodeURIComponent(currentSymbol) + '&limit=10');
                const data = await res.json().catch(() => ({}));
                const records = data.records || [];
                const pipelines = data.pipelines || {}; // 新字段：包含 forward 和 backward
                const pipeline = data.pipeline; // 向后兼容：主要 pipeline
                // #region agent log
                fetch('http://127.0.0.1:7242/ingest/4eef1b1b-0b2f-4cb7-bf0e-18bee09610d5',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({location:'brick-moving-detail.html:loadWithdrawHistory',message:'withdraw history loaded',data:{recordCount:records.length,pipelineKeys:Object.keys(pipelines),pipelineData:pipeline?{status:pipeline.status,nodeCount:(pipeline.nodes||[]).length}:null,activeRunPipelines:JSON.parse(JSON.stringify(activeRunPipelines))},timestamp:Date.now(),hypothesisId:'H9,H10'})}).catch(()=>{});
                // #endregion
                
                // 显示 pipeline 可视化（支持多个 pipeline）
                // 重要：渲染到子元素 withdrawVizForward / withdrawVizBackward 中，
                // 而非直接替换 withdrawPipelineViz 的 innerHTML，否则会销毁子 DOM 元素，
                // 导致 updateWithdrawProgressBox 无法找到这些元素来显示运行状态。
                // 按方向独立判断：如果某方向有活跃轮询 (activeRunPipelines)，由 updateWithdrawProgressBox 负责渲染该方向；
                // 否则由本函数渲染（显示 idle/completed/failed 等静态状态）。
                let hasRunningPipeline = false;
                const fwdVizEl = document.getElementById('withdrawVizForward');
                const bwdVizEl = document.getElementById('withdrawVizBackward');
                const emptyVizEl = document.getElementById('withdrawVizEmpty');
                let anyPipelineRendered = false;
                
                if (pipelines && Object.keys(pipelines).length > 0) {
                    // 分别渲染 forward 和 backward 到各自子元素（仅渲染非活跃方向）
                    for (const dir of ['forward', 'backward']) {
                        const dirVizEl = dir === 'forward' ? fwdVizEl : bwdVizEl;
                        const dirPipeline = pipelines[dir];
                        if (!dirVizEl) continue;
                        
                        // 如果该方向正在被 updateWithdrawProgressBox 轮询，跳过（不覆盖实时进度）
                        if (activeRunPipelines[dir]) {
                            hasRunningPipeline = true;
                            anyPipelineRendered = true;
                            continue;
                        }
                        
                        if (dirPipeline && dirPipeline.nodes && dirPipeline.nodes.length > 0) {
                            const dirLabel = dir === 'forward' ? 'A→B (Forward)' : 'B→A (Backward)';
                            dirVizEl.innerHTML = '<div style="font-size:11px; color:#888; margin-bottom:4px;">' + dirLabel + '</div>' + renderSinglePipelineVisualization(dirPipeline);
                            anyPipelineRendered = true;
                            if (dirPipeline.status === 'running') {
                                hasRunningPipeline = true;
                                // 同步 activeRunPipelines 并启动轮询
                                if (dirPipeline.pipelineId) {
                                    activeRunPipelines[dir] = dirPipeline.pipelineId;
                                    startWithdrawPoll();
                                    console.log(`[${dir}] loadWithdrawHistory: 恢复 pipeline 状态追踪: ${dirPipeline.pipelineId}`);
                                }
                            }
                        } else {
                            dirVizEl.innerHTML = '';
                        }
                    }
                } else if (pipeline && pipeline.nodes && pipeline.nodes.length > 0) {
                    // 向后兼容：单个 pipeline 渲染到 forward 子元素
                    if (fwdVizEl && !activeRunPipelines['forward']) {
                        fwdVizEl.innerHTML = renderSinglePipelineVisualization(pipeline);
                        anyPipelineRendered = true;
                    }
                    if (bwdVizEl && !activeRunPipelines['backward']) bwdVizEl.innerHTML = '';
                    hasRunningPipeline = pipeline.status === 'running';
                } else {
                    // 无 pipeline 数据时，只清空非活跃方向
                    if (fwdVizEl && !activeRunPipelines['forward']) fwdVizEl.innerHTML = '';
                    if (bwdVizEl && !activeRunPipelines['backward']) bwdVizEl.innerHTML = '';
                }
                
                if (emptyVizEl) {
                    emptyVizEl.style.display = (anyPipelineRendered || activeRunPipelines.forward || activeRunPipelines.backward) ? 'none' : 'block';
                }
                
                // 如果 pipeline 正在运行，启动轮询
                if (hasRunningPipeline && !withdrawHistoryPollInterval) {
                    withdrawHistoryPollInterval = setInterval(loadWithdrawHistory, 2000); // 每2秒更新一次
                } else if (!hasRunningPipeline && withdrawHistoryPollInterval) {
                    clearInterval(withdrawHistoryPollInterval);
                    withdrawHistoryPollInterval = null;
                }
                
                // 显示提币记录
                if (!Array.isArray(records) || records.length === 0) {
                    el.innerHTML = '<div style="color:#666; font-size:11px;">暂无提币记录</div>';
                    return;
                }
                let html = '';
                records.forEach(r => {
                    html += '<div style="padding:4px 0; border-bottom:1px solid #333; font-size:11px;">' +
                        (r.createTime || '-') + ' ' + (r.amount != null ? r.amount : '-') + ' ' + (r.asset || '') + ' → ' + (r.network || '-') + ' ' + (r.status || '') + '</div>';
                });
                el.innerHTML = html;
            } catch (e) {
                if (vizEl) vizEl.innerHTML = '<div style="color:#f43f5e;">加载失败: ' + e.message + '</div>';
                el.innerHTML = '<div style="color:#666;">加载失败</div>';
            }
        }
        
        function renderPipelinesVisualization(container, pipelines) {
            if (!container || !pipelines || Object.keys(pipelines).length === 0) {
                if (container) container.innerHTML = '<div style="color:#666;">无 pipeline 信息</div>';
                return;
            }
            
            let html = '';
            const directions = ['forward', 'backward'];
            const directionLabels = { 'forward': 'A→B (Forward)', 'backward': 'B→A (Backward)' };
            
            for (const dir of directions) {
                const pipeline = pipelines[dir];
                if (!pipeline || !pipeline.nodes || pipeline.nodes.length === 0) {
                    continue;
                }
                
                html += '<div style="margin-bottom:12px;">';
                html += '<div style="font-size:11px; color:#888; margin-bottom:4px;">' + (directionLabels[dir] || dir) + '</div>';
                html += renderSinglePipelineVisualization(pipeline);
                html += '</div>';
            }
            
            if (html === '') {
                container.innerHTML = '<div style="color:#666;">无 pipeline 信息</div>';
            } else {
                container.innerHTML = html;
            }
        }
        
        function renderPipelineVisualization(container, pipeline) {
            if (!container || !pipeline || !pipeline.nodes || pipeline.nodes.length === 0) {
                if (container) container.innerHTML = '<div style="color:#666;">无 pipeline 信息</div>';
                return;
            }
            
            container.innerHTML = renderSinglePipelineVisualization(pipeline);
        }
        
        function renderSinglePipelineVisualization(pipeline) {
            if (!pipeline || !pipeline.nodes || pipeline.nodes.length === 0) {
                return '<div style="color:#666;">无 pipeline 信息</div>';
            }
            
            const nodes = pipeline.nodes || [];
            const edges = pipeline.edges || [];
            const status = pipeline.status || 'idle';
            const currentStep = pipeline.currentStep || 0;
            
            let html = '<div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap; font-size:11px;">';
            
            for (let i = 0; i < nodes.length; i++) {
                const node = nodes[i];
                const nodeName = node.name || node.id || 'Node';
                const nodeType = node.type || '';
                
                // 节点样式
                let nodeClass = 'pipeline-node';
                let nodeColor = '#666'; // 默认灰色
                if (status === 'running' && i < currentStep) {
                    nodeColor = '#22c55e'; // 已完成：绿色
                } else if (status === 'running' && i === currentStep) {
                    nodeColor = '#3b82f6'; // 执行中：蓝色
                } else if (status === 'completed') {
                    nodeColor = '#22c55e'; // 已完成：绿色
                } else if (status === 'failed' && i <= currentStep) {
                    nodeColor = i === currentStep ? '#ef4444' : '#22c55e'; // 失败节点：红色，已完成：绿色
                }
                
                html += `<div class="pipeline-node" style="padding:4px 8px; background:${nodeColor}; border-radius:4px; color:#fff; font-weight:500; min-width:60px; text-align:center;">${nodeName}</div>`;
                
                // 箭头（如果不是最后一个节点），跨链时显示协议
                if (i < nodes.length - 1) {
                    const edge = edges.find(e => e.step === i + 1) || {};
                    const edgeStatus = edge.status || 'pending';
                    let arrowColor = '#666'; // 默认灰色
                    let arrowClass = '';
                    
                    if (edgeStatus === 'running') {
                        arrowColor = '#3b82f6';
                        arrowClass = 'pipeline-arrow-running'; // 闪烁动画
                    } else if (edgeStatus === 'success') {
                        arrowColor = '#22c55e';
                    } else if (edgeStatus === 'failed') {
                        arrowColor = '#ef4444';
                    }
                    
                    html += `<div class="pipeline-arrow ${arrowClass}" style="color:${arrowColor}; font-size:16px; font-weight:bold;">→</div>`;
                    if (edge.bridgeProtocol) {
                        html += `<span style="font-size:10px; color:#60a5fa; margin-left:2px;" title="跨链协议">[${edge.bridgeProtocol}]</span>`;
                    }
                }
            }
            
            html += '</div>';
            
            // 添加状态信息
            const statusText = {
                'idle': '未执行',
                'running': '执行中',
                'completed': '已完成',
                'failed': '执行失败',
                'paused': '已暂停'
            }[status] || status;
            
            html += `<div style="margin-top:6px; font-size:10px; color:#888;">状态: ${statusText}${currentStep > 0 ? ' (步骤 ' + currentStep + '/' + (nodes.length - 1) + ')' : ''}</div>`;
            
            // 显示错误信息（如果有）：[WARN] 前缀的显示为黄色警告，其余为红色错误
            if (pipeline.lastError && status === 'failed') {
                const isWarn = pipeline.lastError.startsWith('[WARN]');
                const errColor = isWarn ? '#eab308' : '#ef4444';
                const errLabel = isWarn ? '警告' : '错误';
                const errMsg = isWarn ? pipeline.lastError.replace(/^\[WARN\]\s*/, '') : pipeline.lastError;
                html += `<div style="margin-top:4px; font-size:10px; color:${errColor}; padding:4px; background:#1a1a1a; border-radius:2px; word-break:break-word;">${errLabel}: ${errMsg}</div>`;
            }
            
            return html;
        }
        
        // 添加 CSS 动画
        if (!document.getElementById('pipeline-viz-styles')) {
            const style = document.createElement('style');
            style.id = 'pipeline-viz-styles';
            style.textContent = `
                @keyframes pipeline-arrow-blink {
                    0%, 100% { opacity: 1; }
                    50% { opacity: 0.3; }
                }
                .pipeline-arrow-running {
                    animation: pipeline-arrow-blink 1s infinite;
                }
            `;
            document.head.appendChild(style);
        }
        
        async function loadTriggerFills() {
            const el = document.getElementById('tradeRecordsBox');
            if (!el) return;
            try {
                const res = await fetch('/api/brick-moving/trigger/fills?triggerSymbol=' + encodeURIComponent(currentSymbol) + '&limit=20');
                const data = await res.json().catch(() => ({}));
                const fills = data.fills || [];
                if (fills.length === 0) {
                    el.innerHTML = '<div style="color:#666;">暂无触发记录</div>';
                    return;
                }
                let html = '<table style="width:100%; font-size:11px;"><thead><tr><th>时间</th><th>方向</th><th>数量</th><th>价格</th></tr></thead><tbody>';
                fills.forEach(f => {
                    const dir = (f.side || f.direction || '-');
                    const dirLabel = dir === 'AB' || dir === '+A-B' ? '+A-B' : (dir === 'BA' || dir === '-A+B' ? '-A+B' : dir);
                    html += '<tr><td>' + (f.time || f.createTime || '-') + '</td><td>' + dirLabel + '</td><td>' + (f.qty != null ? f.qty : f.quantity || '-') + '</td><td>' + (f.price != null ? f.price : '-') + '</td></tr>';
                });
                html += '</tbody></table>';
                el.innerHTML = html;
            } catch (e) {
                el.innerHTML = '加载失败: ' + e.message;
            }
        }
        
        async function applyPipelineConfig(direction) {
            if (!currentSymbol) return;
            try {
                const res = await fetch('/api/brick-moving/pipeline/apply', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ triggerSymbol: currentSymbol, direction: direction })
                });
                const data = await res.json().catch(() => ({}));
                if (res.ok && data.status === 'success') {
                    alert('已应用为当前 Pipeline：' + (data.name || data.pipelineId || ''));
                    loadTriggerDetail();
                } else {
                    alert('应用失败：' + (data.error || data.message || res.statusText));
                }
            } catch (e) {
                alert('应用失败：' + e.message);
            }
        }
        
        // 加载黄框「当前使用的 pipeline」并展示提币过程区
        async function loadCurrentPipelineBox() {
            const box = document.getElementById('currentPipelineBox');
            if (!box) return;
            box.innerHTML = '<div style="color: #888;">加载中...</div>';
            try {
                const [fwdRes, bwdRes] = await Promise.all([
                    fetch('/api/brick-moving/pipeline/current?triggerSymbol=' + encodeURIComponent(currentSymbol) + '&direction=forward'),
                    fetch('/api/brick-moving/pipeline/current?triggerSymbol=' + encodeURIComponent(currentSymbol) + '&direction=backward')
                ]);
                const fwd = fwdRes.ok ? await fwdRes.json() : {};
                const bwd = bwdRes.ok ? await bwdRes.json() : {};
                const fwdHas = fwd.id && fwd.nodes && fwd.nodes.length > 0;
                const bwdHas = bwd.id && bwd.nodes && bwd.nodes.length > 0;
                let html = '';
                if (fwdHas) {
                    html += '<div style="margin-bottom: 10px;"><strong style="color: #4ade80;">Forward (A→B) 当前:</strong> ' + (fwd.name || fwd.id) + '<br/><span style="font-size: 12px; color: #888;">' + (fwd.nodes || []).map(n => n.name || n.id).join(' → ') + '</span></div>';
                } else {
                    html += '<div style="margin-bottom: 10px; color: #666;">Forward (A→B) 当前: 暂无，请先配置并应用</div>';
                }
                if (bwdHas) {
                    html += '<div style="margin-bottom: 10px;"><strong style="color: #4ade80;">Backward (B→A) 当前:</strong> ' + (bwd.name || bwd.id) + '<br/><span style="font-size: 12px; color: #888;">' + (bwd.nodes || []).map(n => n.name || n.id).join(' → ') + '</span></div>';
                } else {
                    html += '<div style="margin-bottom: 10px; color: #666;">Backward (B→A) 当前: 暂无，请先配置并应用</div>';
                }
                box.innerHTML = html;
                updateWithdrawProgressBox();
            } catch (e) {
                box.innerHTML = '<div style="color: #f43f5e;">加载失败: ' + e.message + '</div>';
            }
        }
        
        // 更新提币过程区：轮询 pipeline 状态，支持两条 pipeline 同时显示
        async function updateWithdrawProgressBox() {
            const fwdEl = document.getElementById('withdrawVizForward');
            const bwdEl = document.getElementById('withdrawVizBackward');
            const emptyEl = document.getElementById('withdrawVizEmpty');
            if (!fwdEl || !bwdEl) return;

            const directions = ['forward', 'backward'];
            let anyActive = false;

            for (const dir of directions) {
                const pipelineId = activeRunPipelines[dir];
                const vizEl = dir === 'forward' ? fwdEl : bwdEl;
                if (!pipelineId) {
                    // 不清空：保留 loadWithdrawHistory 渲染的静态 pipeline 可视化（如 idle/completed/failed 状态）
                    // 只有活跃方向由本函数负责渲染
                    continue;
                }
                anyActive = true;
                try {
                    const [statusRes, lastRes] = await Promise.all([
                        fetch('/api/pipeline/status?id=' + encodeURIComponent(pipelineId)),
                        fetch('/api/brick-moving/pipeline/last-run?triggerSymbol=' + encodeURIComponent(currentSymbol) + '&direction=' + encodeURIComponent(dir))
                    ]);
                    const status = statusRes.ok ? await statusRes.json() : {};
                    const last = lastRes.ok ? await lastRes.json() : {};
                    const nodes = status.nodes || [];
                    const currentStep = typeof status.currentStep === 'number' ? status.currentStep : (last.currentStep || 0);
                    const statusStr = status.status || last.status || '';
                    const pathNames = nodes.map(n => n.name || n.id);
                    const statusEdges = status.edges || [];
                    const dirLabel = dir === 'forward' ? 'A→B' : 'B→A';
                    let progressHtml = '<div style="margin-bottom:4px;"><strong style="color:#60a5fa;">[' + dirLabel + ']</strong> 状态: <strong>' + statusStr + '</strong></div>';
                    if (pathNames.length > 0) {
                        progressHtml += '<div style="display: flex; align-items: center; gap: 6px; flex-wrap: wrap;">';
                        pathNames.forEach((name, idx) => {
                            if (idx > 0) {
                                const arrowActive = (currentStep === idx && statusStr === 'running');
                                progressHtml += '<span class="pipeline-arrow' + (arrowActive ? ' active-step' : '') + '">→</span>';
                                var edge = statusEdges.find(function(e) { return (e.step === idx || e.step === idx + 1); });
                                if (edge && edge.bridgeProtocol) {
                                    progressHtml += '<span style="font-size:10px; color:#60a5fa;" title="跨链协议">[' + edge.bridgeProtocol + ']</span>';
                                }
                            }
                            var nodeClass = 'node-pending';
                            if (statusStr === 'completed') nodeClass = 'node-success';
                            else if (statusStr === 'failed' && currentStep === idx + 1) nodeClass = 'node-failed';
                            else if (idx + 1 < currentStep) nodeClass = 'node-success';
                            else if (currentStep === idx + 1 && statusStr === 'running') nodeClass = 'node-running';
                            progressHtml += '<span class="pipeline-node ' + nodeClass + '">' + name + '</span>';
                        });
                        progressHtml += '</div>';
                    }
                    vizEl.innerHTML = progressHtml;

                    // 该方向的 pipeline 完成时，只清理该方向
                    if (statusStr === 'completed' || statusStr === 'failed') {
                        activeRunPipelines[dir] = '';
                        const btnId = dir === 'forward' ? 'btnAutoWithdrawForward' : 'btnAutoWithdrawBackward';
                        const btnLabel = dir === 'forward' ? '自动检测并提币 (A→B)' : '自动检测并提币 (B→A)';
                        const btn = document.getElementById(btnId);
                        if (btn) { btn.disabled = false; btn.textContent = btnLabel; }
                        loadWithdrawHistory();
                    }
                } catch (e) {
                    vizEl.innerHTML = '<span style="color:#f43f5e;">[' + (dir === 'forward' ? 'A→B' : 'B→A') + '] 查询失败</span>';
                }
            }

            // 两条都结束时停止轮询
            if (!activeRunPipelines.forward && !activeRunPipelines.backward) {
                stopWithdrawPoll();
            }
            if (emptyEl) {
                emptyEl.style.display = (activeRunPipelines.forward || activeRunPipelines.backward) ? 'none' : 'block';
            }
        }
        
        function startWithdrawPoll() {
            if (withdrawPollTimer) return;
            withdrawPollTimer = setInterval(updateWithdrawProgressBox, 2000);
            updateWithdrawProgressBox();
        }
        function stopWithdrawPoll() {
            if (withdrawPollTimer) {
                clearInterval(withdrawPollTimer);
                withdrawPollTimer = null;
            }
        }
        
        // 自动检测定时器
        let autoDetectTimers = { forward: null, backward: null };
        
        // 启动自动检测并提币：开始定时检测余额并触发提币
        async function startAutoDetectWithdraw(direction) {
            if (!currentSymbol) return;
            
            // 如果已经在运行，先停止
            if (autoDetectTimers[direction]) {
                stopAutoDetectWithdraw(direction);
            }
            
            const btnStart = document.getElementById('btnAutoWithdraw' + (direction === 'forward' ? 'Forward' : 'Backward'));
            const btnStop = document.getElementById('btnStopAutoWithdraw' + (direction === 'forward' ? 'Forward' : 'Backward'));
            
            if (btnStart) {
                btnStart.style.display = 'none';
            }
            if (btnStop) {
                btnStop.style.display = 'block';
            }
            
            // 立即执行一次检测
            await checkAndTriggerWithdraw(direction);
            
            // 每30秒检测一次
            autoDetectTimers[direction] = setInterval(async () => {
                await checkAndTriggerWithdraw(direction);
            }, 30000);
        }
        
        // 停止自动检测并提币
        function stopAutoDetectWithdraw(direction) {
            if (autoDetectTimers[direction]) {
                clearInterval(autoDetectTimers[direction]);
                autoDetectTimers[direction] = null;
            }
            
            const btnStart = document.getElementById('btnAutoWithdraw' + (direction === 'forward' ? 'Forward' : 'Backward'));
            const btnStop = document.getElementById('btnStopAutoWithdraw' + (direction === 'forward' ? 'Forward' : 'Backward'));
            
            if (btnStart) {
                btnStart.style.display = 'block';
            }
            if (btnStop) {
                btnStop.style.display = 'none';
            }
        }
        
        // 检查余额并触发提币
        async function checkAndTriggerWithdraw(direction) {
            if (!currentSymbol) return;
            
            try {
                // ===== 防止循环触发：先检查当前 pipeline 状态 =====
                const histRes = await fetch('/api/brick-moving/withdraw-history?triggerSymbol=' + encodeURIComponent(currentSymbol) + '&limit=1');
                if (histRes.ok) {
                    const histData = await histRes.json().catch(() => ({}));
                    const pipelines = histData.pipelines || {};
                    const pInfo = pipelines[direction];
                    if (pInfo && pInfo.status === 'running') {
                        console.log(`[${direction}] pipeline 正在运行中，跳过本次触发`);
                        // 同步 UI 状态：确保 activeRunPipelines 已设置并启动轮询，
                        // 这样即使页面刷新或 activeRunPipelines 丢失，也能恢复状态显示
                        if (!activeRunPipelines[direction] && pInfo.pipelineId) {
                            activeRunPipelines[direction] = pInfo.pipelineId;
                            startWithdrawPoll();
                            console.log(`[${direction}] 恢复 pipeline 状态追踪: ${pInfo.pipelineId}`);
                        }
                        return;
                    }
                }
                // ===== 防止循环触发 END =====

                // 获取套保配置
                const hedgeRes = await fetch('/api/brick-moving/trigger/hedging?triggerSymbol=' + encodeURIComponent(currentSymbol));
                if (!hedgeRes.ok) {
                    console.warn('获取套保配置失败');
                    return;
                }
                const hedgeData = await hedgeRes.json().catch(() => ({}));
                
                // 检查是否启用了自动充提
                if (!hedgeData.autoWithdrawEnabled) {
                    console.log('自动充提未启用');
                    return;
                }
                
                // 获取pipeline第一个节点的余额
                const balanceRes = await fetch('/api/brick-moving/pipeline/balance?triggerSymbol=' + encodeURIComponent(currentSymbol) + '&direction=' + encodeURIComponent(direction));
                if (!balanceRes.ok) {
                    console.warn('获取余额失败');
                    return;
                }
                const balanceData = await balanceRes.json().catch(() => ({}));
                const currentBalance = balanceData.balance || 0;
                const isBackward = balanceData.isBackward || false;
                
                // 计算阈值
                let threshold = 0;
                if (isBackward && balanceData.usdtThreshold > 0) {
                    // backward 链路：后端已返回 USDT 余额和 USDT 阈值，直接使用
                    threshold = balanceData.usdtThreshold;
                    console.log(`[${direction}] USDT模式: 余额=${currentBalance} USDT, 阈值=${threshold} USDT (balanceAsset=${balanceData.balanceAsset})`);
                } else if (hedgeData.autoWithdrawUseFixed) {
                    // 固定Size模式：使用固定Size或单次交易Size
                    threshold = hedgeData.autoWithdrawFixedSize || hedgeData.size || 0;
                } else {
                    // 仓位百分比模式：仓位 * 百分比
                    threshold = (hedgeData.position || 0) * (hedgeData.autoWithdrawPercentage || 0);
                }
                
                console.log(`[${direction}] 当前余额: ${currentBalance} (${balanceData.balanceAsset || 'unknown'}), 阈值: ${threshold}`);
                
                // 如果余额超过阈值，触发提币
                if (currentBalance > threshold && threshold > 0) {
                    console.log(`[${direction}] 余额超过阈值，触发提币`);
                    await runAutoDetectWithdraw(direction);
                }
            } catch (e) {
                console.error('检查余额失败:', e);
            }
        }
        
        // 执行一次提币（原 runAutoDetectWithdraw 逻辑）
        async function runAutoDetectWithdraw(direction) {
            if (!currentSymbol) return;
            try {
                const res = await fetch('/api/brick-moving/pipeline/run?triggerSymbol=' + encodeURIComponent(currentSymbol) + '&direction=' + encodeURIComponent(direction), { method: 'POST' });
                const data = await res.json().catch(() => ({}));
                if (!res.ok) {
                    // 409 = pipeline 正在运行或冷却中，属于正常情况，不告警
                    if (res.status === 409) {
                        console.log(`[${direction}] pipeline 冷却/运行中: ` + (data.error || res.statusText));
                    } else {
                        console.error('启动失败: ' + (data.error || res.statusText));
                    }
                    return;
                }
                if (data.status === 'started' && data.pipelineId) {
                    activeRunPipelines[direction] = data.pipelineId;
                    startWithdrawPoll();
                }
            } catch (e) {
                console.error('请求失败: ' + e.message);
            }
        }
        
        // 切换自动充提模式
        function toggleAutoWithdrawMode() {
            const mode = document.getElementById('autoWithdrawMode').value;
            const fixedContainer = document.getElementById('autoWithdrawFixedContainer');
            const percentageContainer = document.getElementById('autoWithdrawPercentageContainer');
            if (mode === 'fixed') {
                if (fixedContainer) fixedContainer.style.display = 'block';
                if (percentageContainer) percentageContainer.style.display = 'none';
            } else {
                if (fixedContainer) fixedContainer.style.display = 'none';
                if (percentageContainer) percentageContainer.style.display = 'block';
            }
        }
        
        // 自动保存套保配置（编辑完成自动保存，不显示提示）
        let autoSaveTimer = null;
        async function autoSaveHedgingConfig() {
            // 防抖：延迟500ms后保存
            if (autoSaveTimer) {
                clearTimeout(autoSaveTimer);
            }
            autoSaveTimer = setTimeout(async () => {
                await updateHedgingConfig(true); // true 表示静默保存
            }, 500);
        }
        
        // 保存套保配置
        async function updateHedgingConfig(silent = false) {
            const exchangeType = document.getElementById('hedgingExchange').value;
            const hedgingSymbol = document.getElementById('hedgingSymbol').value;
            const sizeInput = document.getElementById('hedgingSize');
            const size = parseFloat(sizeInput ? sizeInput.value : 0) || 0;
            const syncWithTriggerSize = document.getElementById('hedgingSyncSize').checked;
            const positionInput = document.getElementById('hedgingPosition');
            const position = parseFloat(positionInput ? positionInput.value : 0) || 0;
            
            // 自动充提配置（根据是否配置了提币方式自动判断是否启用）
            const autoWithdrawMode = document.getElementById('autoWithdrawMode') ? document.getElementById('autoWithdrawMode').value : 'fixed';
            const autoWithdrawUseFixed = autoWithdrawMode === 'fixed';
            const autoWithdrawFixedSizeInput = document.getElementById('autoWithdrawFixedSize');
            const autoWithdrawFixedSize = parseFloat(autoWithdrawFixedSizeInput ? autoWithdrawFixedSizeInput.value : 0) || 0;
            const autoWithdrawPercentageInput = document.getElementById('autoWithdrawPercentage');
            const autoWithdrawPercentage = parseFloat(autoWithdrawPercentageInput ? autoWithdrawPercentageInput.value : 0) || 0;
            // 如果配置了提币方式（固定size > 0 或 百分比 > 0），则启用自动充提
            const autoWithdrawEnabled = (autoWithdrawUseFixed && autoWithdrawFixedSize > 0) || (!autoWithdrawUseFixed && autoWithdrawPercentage > 0);
            
            try {
                const res = await fetch('/api/brick-moving/trigger/hedging', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        symbol: currentSymbol,
                        enabled: true,
                        exchangeType: exchangeType,
                        hedgingSymbol: hedgingSymbol || currentSymbol,
                        size: size,
                        syncWithTriggerSize: syncWithTriggerSize,
                        position: position,
                        autoWithdrawEnabled: autoWithdrawEnabled,
                        autoWithdrawUseFixed: autoWithdrawUseFixed,
                        autoWithdrawFixedSize: autoWithdrawFixedSize,
                        autoWithdrawPercentage: autoWithdrawPercentage
                    })
                });
                
                if (res.ok) {
                    const statusEl = document.getElementById('hedgingStatus');
                    if (statusEl) {
                        if (silent) {
                            statusEl.textContent = '已自动保存';
                            setTimeout(() => { statusEl.textContent = ''; }, 2000);
                        } else {
                            statusEl.textContent = '配置已保存 (Size: ' + size + ', Position: ' + position + ')';
                        }
                    }
                    if (!silent) {
                        alert('套保配置已保存');
                    }
                } else {
                    const errorText = await res.text();
                    if (!silent) {
                        alert('保存失败: ' + errorText);
                    } else {
                        console.error('自动保存失败: ' + errorText);
                    }
                }
            } catch (error) {
                if (!silent) {
                    alert('保存失败: ' + error.message);
                } else {
                    console.error('自动保存失败: ' + error.message);
                }
            }
        }
        
        // 停止套保操作
        async function stopHedgingOperation(direction) {
            if (!currentSymbol) return;
            if (!confirm('确定停止套保操作 (' + (direction === 'forward' ? 'A→B' : 'B→A') + ')？')) return;
            
            try {
                // 停止自动检测提币
                stopAutoDetectWithdraw(direction);
                
                // 这里可以添加其他停止套保操作的逻辑
                // 例如：停止正在运行的 pipeline、平仓等
                
                alert('套保操作已停止');
            } catch (e) {
                alert('停止失败: ' + e.message);
            }
        }
        
        // 更新Trigger配置（含链上滑点、Gas 乘数、Gas Limit）
        async function updateTriggerConfig() {
            const size = parseFloat(document.getElementById('triggerSize').value);
            const thresholdAB = parseFloat(document.getElementById('triggerThresholdAB').value);
            const thresholdBA = parseFloat(document.getElementById('triggerThresholdBA').value);
            const enabledAB = document.getElementById('triggerEnableAB') ? document.getElementById('triggerEnableAB').checked : false;
            const enabledBA = document.getElementById('triggerEnableBA') ? document.getElementById('triggerEnableBA').checked : false;
            
            const body = {
                symbol: currentSymbol,
                size: size,
                thresholdAB: thresholdAB,
                thresholdBA: thresholdBA,
                enabledAB: enabledAB,
                enabledBA: enabledBA
            };
            var el = document.getElementById('onChainSlippageA');
            if (el) body.onChainSlippageA = el.value;
            el = document.getElementById('gasMultiplierA');
            if (el) body.gasMultiplierA = parseFloat(el.value) || 1;
            el = document.getElementById('onChainGasLimitA');
            if (el) body.onChainGasLimitA = el.value;
            el = document.getElementById('onChainSlippageB');
            if (el) body.onChainSlippageB = el.value;
            el = document.getElementById('gasMultiplierB');
            if (el) body.gasMultiplierB = parseFloat(el.value) || 1;
            el = document.getElementById('onChainGasLimitB');
            if (el) body.onChainGasLimitB = el.value;
            
            try {
                const res = await fetch('/api/brick-moving/trigger/config', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                
                if (res.ok) {
                    alert('Trigger 配置已更新');
                    loadTriggerDetail(); // 重新加载
                } else {
                    alert('更新失败');
                }
            } catch (error) {
                alert('更新失败: ' + error.message);
            }
        }
        
        // 更新自动充提配置
        async function updateAutoTransferConfig() {
            const enabled = document.getElementById('autoTransferEnabled').checked;
            
            try {
                const res = await fetch('/api/brick-moving/trigger/auto-transfer', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        symbol: currentSymbol,
                        enabled: enabled
                    })
                });
                
                if (res.ok) {
                    alert('自动充提配置已更新');
                    loadTriggerDetail(); // 重新加载
                } else {
                    alert('更新失败');
                }
            } catch (error) {
                alert('更新失败: ' + error.message);
            }
        }
        
        // 启动Trigger
        async function startTrigger() {
            try {
                const res = await fetch('/api/brick-moving/trigger/start?symbol=' + encodeURIComponent(currentSymbol), { method: 'POST' });
                if (res.ok) {
                    alert('Trigger 已启动');
                    loadTriggerDetail();
                } else {
                    alert('启动失败');
                }
            } catch (error) {
                alert('启动失败: ' + error.message);
